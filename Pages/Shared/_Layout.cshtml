@inject MiniApp.Features.Localization.ILocalizationService Localization
@{
    var isAdminPath = Context?.Request.Path.StartsWithSegments("/Admin", StringComparison.OrdinalIgnoreCase) ?? false;
    var cookieLang = Context?.Request.Cookies["AdminUiLanguage"];
    var selectedAdminLang = string.Equals(cookieLang, "ru", StringComparison.OrdinalIgnoreCase)
        ? "ru"
        : string.Equals(cookieLang, "uz", StringComparison.OrdinalIgnoreCase)
            ? "uz"
            : "en";
    var currentAdminReturnUrl = (Context?.Request.Path.Value ?? "/Admin") + (Context?.Request.QueryString.Value ?? string.Empty);
    var requestAborted = Context?.RequestAborted ?? CancellationToken.None;
    var navHomeText = isAdminPath
        ? await Localization.GetTextAsync(selectedAdminLang, "admin.layout.home", "Home", requestAborted)
        : "Home";
    var navPrivacyText = isAdminPath
        ? await Localization.GetTextAsync(selectedAdminLang, "admin.layout.privacy", "Privacy", requestAborted)
        : "Privacy";
    var languageLabelText = await Localization.GetTextAsync(selectedAdminLang, "admin.layout.language", "Language", requestAborted);
}
<!DOCTYPE html>
<html lang="@selectedAdminLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MiniApp.styles.css" asp-append-version="true" />

    <!-- Telegram Mini App support script: -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
</head>
<body class="@(isAdminPath ? "admin-layout" : "public-layout")">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">MiniApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">@navHomeText</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">@navPrivacyText</a>
                        </li>
                    </ul>
                    @if (isAdminPath)
                    {
                        <form class="d-flex align-items-center gap-2" method="post" action="/Admin/set-language">
                            <input type="hidden" name="returnUrl" value="@currentAdminReturnUrl" />
                            <label class="small text-muted mb-0" for="adminLangSelect">@languageLabelText</label>
                            <select id="adminLangSelect" name="lang" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="en" selected="@(selectedAdminLang == "en")">English</option>
                                <option value="ru" selected="@(selectedAdminLang == "ru")">Русский</option>
                                <option value="uz" selected="@(selectedAdminLang == "uz")">O'zbek</option>
                            </select>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container layout-content @(isAdminPath ? "admin-content" : string.Empty)">
        <main role="main" class="pb-3 @(isAdminPath ? "admin-main" : string.Empty)">
            @RenderBody()
        </main>
    </div>

    @if (!isAdminPath)
    {
        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2024 - MiniApp - <a asp-area="" asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>