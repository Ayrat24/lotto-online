@page
@model MiniApp.Pages.Admin.ReferralsModel
@{
    ViewData["Title"] = "Referrals";
}

<h1>Referral program</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Program settings</h5>
        <form method="post" asp-page-handler="Save" class="row g-3 mt-1">
            @Html.AntiForgeryToken()

            <div class="col-12">
                <div class="form-check form-switch">
                    <input asp-for="Enabled" class="form-check-input" />
                    <label asp-for="Enabled" class="form-check-label">Enabled</label>
                </div>
            </div>

            <div class="col-md-4">
                <label asp-for="InviterBonusAmount" class="form-label">Inviter bonus amount (USD)</label>
                <input asp-for="InviterBonusAmount" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-md-4">
                <label asp-for="InviteeBonusAmount" class="form-label">Invitee bonus amount (USD)</label>
                <input asp-for="InviteeBonusAmount" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-md-4">
                <label asp-for="MinQualifyingDepositAmount" class="form-label">Minimum qualifying deposit (USD)</label>
                <input asp-for="MinQualifyingDepositAmount" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-md-6">
                <label asp-for="EligibilityWindowDays" class="form-label">Eligibility window (days, 0 = no limit)</label>
                <input asp-for="EligibilityWindowDays" class="form-control" type="number" min="0" step="1" />
            </div>

            <div class="col-md-6">
                <label asp-for="MonthlyInviterBonusCap" class="form-label">Monthly inviter cap (USD, 0 = no cap)</label>
                <input asp-for="MonthlyInviterBonusCap" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-12">
                <button class="btn btn-primary" type="submit">Save settings</button>
            </div>
        </form>

        <hr />
        <div class="text-muted small">
            Last updated: @Model.Settings.UpdatedAtUtc.ToString("u") by @(string.IsNullOrWhiteSpace(Model.Settings.UpdatedByAdmin) ? "-" : Model.Settings.UpdatedByAdmin)
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Recent referral rewards</h5>
        @if (Model.RecentRewards.Count == 0)
        {
            <div class="alert alert-secondary mb-0">No referral rewards yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>Time (UTC)</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Inviter</th>
                        <th>Invitee</th>
                        <th>Recipient</th>
                        <th>Deposit</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.RecentRewards)
                    {
                        <tr>
                            <td>@row.CreatedAtUtc.ToString("u")</td>
                            <td>@row.Type</td>
                            <td>@row.Amount.ToString("0.00")</td>
                            <td><code>@row.InviterUserId</code> / <code>@row.InviterTelegramUserId</code></td>
                            <td><code>@row.InviteeUserId</code> / <code>@row.InviteeTelegramUserId</code></td>
                            <td><code>@row.RecipientUserId</code> / <code>@row.RecipientTelegramUserId</code></td>
                            <td><code>@row.DepositIntentId</code></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

