@page
@model MiniApp.Pages.Admin.ReferralsModel
@{
    ViewData["Title"] = Model.T("admin.referrals.title", "Referrals");
}

<h1>@Model.T("admin.referrals.heading", "Referral program")</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.referrals.settings.title", "Program settings")</h5>
        <form method="post" asp-page-handler="Save" class="row g-3 mt-1">
            @Html.AntiForgeryToken()

            <div class="col-12">
                <div class="form-check form-switch">
                    <input asp-for="Enabled" class="form-check-input" />
                    <label asp-for="Enabled" class="form-check-label">@Model.T("admin.referrals.settings.enabled", "Enabled")</label>
                </div>
            </div>

            <div class="col-md-4">
                <label asp-for="InviterBonusAmount" class="form-label">@Model.T("admin.referrals.settings.inviterBonus", "Inviter bonus amount (USD)")</label>
                <input asp-for="InviterBonusAmount" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-md-4">
                <label asp-for="InviteeBonusAmount" class="form-label">@Model.T("admin.referrals.settings.inviteeBonus", "Invitee bonus amount (USD)")</label>
                <input asp-for="InviteeBonusAmount" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-md-4">
                <label asp-for="MinQualifyingDepositAmount" class="form-label">@Model.T("admin.referrals.settings.minDeposit", "Minimum qualifying deposit (USD)")</label>
                <input asp-for="MinQualifyingDepositAmount" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-md-6">
                <label asp-for="EligibilityWindowDays" class="form-label">@Model.T("admin.referrals.settings.windowDays", "Eligibility window (days, 0 = no limit)")</label>
                <input asp-for="EligibilityWindowDays" class="form-control" type="number" min="0" step="1" />
            </div>

            <div class="col-md-6">
                <label asp-for="MonthlyInviterBonusCap" class="form-label">@Model.T("admin.referrals.settings.monthlyCap", "Monthly inviter cap (USD, 0 = no cap)")</label>
                <input asp-for="MonthlyInviterBonusCap" class="form-control" type="number" min="0" step="0.01" />
            </div>

            <div class="col-12">
                <button class="btn btn-primary" type="submit">@Model.T("admin.referrals.settings.save", "Save settings")</button>
            </div>
        </form>

        <hr />
        <div class="text-muted small">
            @Model.T("admin.referrals.settings.lastUpdated", "Last updated"): @Model.Settings.UpdatedAtUtc.ToString("u") @Model.T("admin.referrals.settings.by", "by") @(string.IsNullOrWhiteSpace(Model.Settings.UpdatedByAdmin) ? "-" : Model.Settings.UpdatedByAdmin)
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.referrals.rewards.title", "Recent referral rewards")</h5>
        @if (Model.RecentRewards.Count == 0)
        {
            <div class="alert alert-secondary mb-0">@Model.T("admin.referrals.rewards.empty", "No referral rewards yet.")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>@Model.T("admin.referrals.rewards.timeUtc", "Time (UTC)")</th>
                        <th>@Model.T("admin.referrals.rewards.type", "Type")</th>
                        <th>@Model.T("admin.referrals.rewards.amount", "Amount")</th>
                        <th>@Model.T("admin.referrals.rewards.inviter", "Inviter")</th>
                        <th>@Model.T("admin.referrals.rewards.invitee", "Invitee")</th>
                        <th>@Model.T("admin.referrals.rewards.recipient", "Recipient")</th>
                        <th>@Model.T("admin.referrals.rewards.deposit", "Deposit")</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.RecentRewards)
                    {
                        <tr>
                            <td>@row.CreatedAtUtc.ToString("u")</td>
                            <td>@row.Type</td>
                            <td>@row.Amount.ToString("0.00")</td>
                            <td><code>@row.InviterUserId</code> / <code>@row.InviterTelegramUserId</code></td>
                            <td><code>@row.InviteeUserId</code> / <code>@row.InviteeTelegramUserId</code></td>
                            <td><code>@row.RecipientUserId</code> / <code>@row.RecipientTelegramUserId</code></td>
                            <td><code>@row.DepositIntentId</code></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

