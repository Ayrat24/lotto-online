@page "{id:long}"
@model MiniApp.Pages.Admin.Draws.ResultModel
@{
    ViewData["Title"] = "Draw results";
}

<h1>Draw results</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

@if (Model.Draw is null)
{
    <a class="btn btn-secondary" asp-page="/Admin/Draws">Back</a>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="card-title mb-0">Draw #@Model.Draw.Id</h5>
                <div class="d-flex gap-2">
                    <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Draws/Edit" asp-route-id="@Model.Draw.Id">Edit draw</a>
                    <a class="btn btn-sm btn-secondary" asp-page="/Admin/Draws">Back to draws</a>
                </div>
            </div>
            <div class="mt-3">
                <div><strong>State:</strong> @Model.Draw.State</div>
                <div><strong>Result numbers:</strong> <code>@(string.IsNullOrWhiteSpace(Model.Draw.Numbers) ? "-" : Model.Draw.Numbers)</code></div>
                <div><strong>Created (UTC):</strong> @Model.Draw.CreatedAtUtc.ToString("u")</div>
            </div>
        </div>
    </div>

    @if (Model.Tiers.Count > 0)
    {
        @foreach (var tier in Model.Tiers)
        {
            <div class="card mt-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">Tier @tier.TierLabel</h5>
                    <div class="row g-2 mb-3">
                        <div class="col-sm-6 col-lg-3"><strong>Prize pool:</strong> @tier.PrizePool.ToString("0.00")</div>
                        <div class="col-sm-6 col-lg-3"><strong>Winning tickets:</strong> @tier.WinningTicketsCount</div>
                        <div class="col-sm-6 col-lg-3"><strong>Per ticket:</strong> @tier.WinningAmountPerTicket.ToString("0.00")</div>
                        <div class="col-sm-6 col-lg-3"><strong>Total paid:</strong> @( (tier.WinningAmountPerTicket * tier.WinningTicketsCount).ToString("0.00") )</div>
                    </div>

                    @if (tier.Winners.Count == 0)
                    {
                        <div class="alert alert-secondary mb-0">No winners in this tier.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                <tr>
                                    <th>User Id</th>
                                    <th>Telegram User Id</th>
                                    <th>Number</th>
                                    <th>Created (UTC)</th>
                                    <th>Last seen (UTC)</th>
                                    <th>Winning tickets</th>
                                    <th>Winning amount</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var w in tier.Winners)
                                {
                                    <tr>
                                        <td>@w.UserId</td>
                                        <td>@w.TelegramUserId</td>
                                        <td>@(string.IsNullOrWhiteSpace(w.Number) ? "-" : w.Number)</td>
                                        <td>@w.CreatedAtUtc.ToString("u")</td>
                                        <td>@w.LastSeenAtUtc.ToString("u")</td>
                                        <td>@w.WinningTicketsCount</td>
                                        <td><strong>@w.WinningAmount.ToString("0.00")</strong></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    }
}

