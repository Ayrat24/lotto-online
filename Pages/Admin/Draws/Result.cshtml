@page "{id:long}"
@model MiniApp.Pages.Admin.Draws.ResultModel
@{
    ViewData["Title"] = Model.T("admin.draws.result.title", "Draw results");
}

<h1>@Model.T("admin.draws.result.heading", "Draw results")</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

@if (Model.Draw is null)
{
    <a class="btn btn-secondary" asp-page="/Admin/Draws">@Model.T("admin.draws.result.back", "Back")</a>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="card-title mb-0">@Model.T("admin.draws.result.drawPrefix", "Draw #")@Model.Draw.Id</h5>
                <div class="d-flex gap-2">
                    <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Draws/Edit" asp-route-id="@Model.Draw.Id">@Model.T("admin.draws.result.editDraw", "Edit draw")</a>
                    <a class="btn btn-sm btn-secondary" asp-page="/Admin/Draws">@Model.T("admin.draws.result.backToDraws", "Back to draws")</a>
                </div>
            </div>
            <div class="mt-3">
                <div><strong>@Model.T("admin.draws.result.state", "State"):</strong> @Model.Draw.State</div>
                <div><strong>@Model.T("admin.draws.result.numbers", "Result numbers"):</strong> <code>@(string.IsNullOrWhiteSpace(Model.Draw.Numbers) ? "-" : Model.Draw.Numbers)</code></div>
                <div><strong>@Model.T("admin.draws.result.createdUtc", "Created (UTC)"):</strong> @Model.Draw.CreatedAtUtc.ToString("u")</div>
            </div>
        </div>
    </div>

    @if (Model.Tiers.Count > 0)
    {
        @foreach (var tier in Model.Tiers)
        {
            <div class="card mt-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">@Model.T("admin.draws.result.tier", "Tier") @tier.TierLabel</h5>
                    <div class="row g-2 mb-3">
                        <div class="col-sm-6 col-lg-3"><strong>@Model.T("admin.draws.result.prizePool", "Prize pool"):</strong> @tier.PrizePool.ToString("0.00")</div>
                        <div class="col-sm-6 col-lg-3"><strong>@Model.T("admin.draws.result.winningTickets", "Winning tickets"):</strong> @tier.WinningTicketsCount</div>
                        <div class="col-sm-6 col-lg-3"><strong>@Model.T("admin.draws.result.perTicket", "Per ticket"):</strong> @tier.WinningAmountPerTicket.ToString("0.00")</div>
                        <div class="col-sm-6 col-lg-3"><strong>@Model.T("admin.draws.result.totalPaid", "Total paid"):</strong> @( (tier.WinningAmountPerTicket * tier.WinningTicketsCount).ToString("0.00") )</div>
                    </div>

                    @if (tier.Winners.Count == 0)
                    {
                        <div class="alert alert-secondary mb-0">@Model.T("admin.draws.result.noWinners", "No winners in this tier.")</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                <tr>
                                    <th>@Model.T("admin.draws.result.table.userId", "User Id")</th>
                                    <th>@Model.T("admin.draws.result.table.telegramUserId", "Telegram User Id")</th>
                                    <th>@Model.T("admin.draws.result.table.number", "Number")</th>
                                    <th>@Model.T("admin.draws.result.table.createdUtc", "Created (UTC)")</th>
                                    <th>@Model.T("admin.draws.result.table.lastSeenUtc", "Last seen (UTC)")</th>
                                    <th>@Model.T("admin.draws.result.table.winningTickets", "Winning tickets")</th>
                                    <th>@Model.T("admin.draws.result.table.winningAmount", "Winning amount")</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var w in tier.Winners)
                                {
                                    <tr>
                                        <td>@w.UserId</td>
                                        <td>@w.TelegramUserId</td>
                                        <td>@(string.IsNullOrWhiteSpace(w.Number) ? "-" : w.Number)</td>
                                        <td>@w.CreatedAtUtc.ToString("u")</td>
                                        <td>@w.LastSeenAtUtc.ToString("u")</td>
                                        <td>@w.WinningTicketsCount</td>
                                        <td><strong>@w.WinningAmount.ToString("0.00")</strong></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    }
}

