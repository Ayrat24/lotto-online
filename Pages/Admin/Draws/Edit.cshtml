@page "{id:long}"
@model MiniApp.Pages.Admin.Draws.EditModel
@{
    ViewData["Title"] = "Edit draw";
}

<h1>Edit draw</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

@if (Model.SelectedDraw is null)
{
    <div class="alert alert-warning mt-3">Draw not found.</div>
    <a class="btn btn-secondary" asp-page="/Admin/Draws">Back</a>
}
else if (Model.CanEdit)
{
    <form method="post" class="mt-3">
        <input type="hidden" name="ticketPage" value="@Model.TicketsPage" />
        <input type="hidden" name="ticketNumbers" value="@Model.SelectedTicketNumbers" />
        <div class="mb-3">
            <label class="form-label">Id</label>
            <input class="form-control" value="@Model.SelectedDraw.Id" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">State</label>
            <select asp-for="State" class="form-select">
                <option value="active">active</option>
                <option value="upcoming">upcoming</option>
            </select>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Prize pool 3/5</label>
                <input asp-for="PrizePoolMatch3" type="number" min="0" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Prize pool 4/5</label>
                <input asp-for="PrizePoolMatch4" type="number" min="0" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Prize pool 5/5</label>
                <input asp-for="PrizePoolMatch5" type="number" min="0" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Ticket cost</label>
                <input asp-for="TicketCost" type="number" min="0.01" step="0.01" class="form-control" />
            </div>
        </div>

        <div class="form-text mt-2">Total pool: @((Model.PrizePoolMatch3 + Model.PrizePoolMatch4 + Model.PrizePoolMatch5).ToString("0.00"))</div>

        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Save</button>
            <a class="btn btn-secondary" asp-page="/Admin/Draws">Back</a>
        </div>
    </form>

    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Execute draw</h5>
            <p class="text-muted mb-3">You can execute using manual numbers or execute with randomized numbers.</p>

            @if (Model.State != "active")
            {
                <div class="alert alert-secondary mb-0">Only active draws can be executed. Set state to <strong>active</strong>, save, then execute.</div>
            }
            else
            {
                <form method="post" asp-page-handler="Execute" class="row g-3 align-items-end">
                    <input type="hidden" name="ticketPage" value="@Model.TicketsPage" />
                    <input type="hidden" name="ticketNumbers" value="@Model.SelectedTicketNumbers" />
                    <div class="col-md-6">
                        <label asp-for="ExecuteNumbers" class="form-label">Manual result numbers</label>
                        <input asp-for="ExecuteNumbers" class="form-control" placeholder="1,5,12,23,36" />
                        <div class="form-text">Enter 5 unique numbers between 1 and 36 separated by commas.</div>
                    </div>
                    <div class="col-md-6 d-flex gap-2 flex-wrap">
                        <button type="button" id="randomizePreviewBtn" class="btn btn-outline-secondary">Randomize</button>
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Execute draw #@Model.SelectedDraw.Id with these numbers?');">Execute with manual numbers</button>
                        <button type="submit" name="randomize" value="true" class="btn btn-danger" onclick="return confirm('Execute draw #@Model.SelectedDraw.Id with randomized numbers?');">Execute randomized</button>
                    </div>
                </form>
            }
        </div>
    </div>
}
else
{
    <a class="btn btn-secondary mt-3" asp-page="/Admin/Draws">Back</a>
}

@section Scripts {
    <script>
        (function () {
            var btn = document.getElementById('randomizePreviewBtn');
            var input = document.getElementById('ExecuteNumbers');
            if (!btn || !input) return;

            btn.addEventListener('click', function () {
                var numbers = new Set();
                while (numbers.size < 5) {
                    numbers.add(Math.floor(Math.random() * 36) + 1);
                }

                var arr = Array.from(numbers).sort(function (a, b) { return a - b; });
                input.value = arr.join(',');
            });
        })();
    </script>
}

@if (Model.SelectedDraw is not null)
{
    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Bought tickets</h5>
            <p class="text-muted mb-3">Showing tickets for draw #@Model.SelectedDraw.Id. Ordered by how often each number set was selected.</p>

            @if (Model.TicketsTotalCount == 0)
            {
                <div class="alert alert-secondary mb-0">No tickets bought for this draw yet.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                        <tr>
                            <th>Numbers</th>
                            <th>Count among all users</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var t in Model.Tickets)
                        {
                            <tr>
                                <td><code>@t.Numbers</code></td>
                                <td><span class="badge text-bg-light border text-dark">@t.SelectionCount</span></td>
                                <td>
                                    <a class="btn btn-sm @(Model.SelectedTicketNumbers == t.Numbers ? "btn-primary" : "btn-outline-primary")"
                                       asp-page="/Admin/Draws/Edit"
                                       asp-route-id="@Model.SelectedDraw.Id"
                                       asp-route-ticketPage="@Model.TicketsPage"
                                       asp-route-ticketNumbers="@t.Numbers">Users</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                    <small class="text-muted">Page @Model.TicketsPage of @Model.TicketsTotalPages (@Model.TicketsTotalCount combinations)</small>
                    <div class="btn-group" role="group" aria-label="Ticket pagination">
                        <a class="btn btn-sm btn-outline-secondary @(Model.TicketsPage <= 1 ? "disabled" : null)"
                           asp-page="/Admin/Draws/Edit"
                           asp-route-id="@Model.SelectedDraw.Id"
                           asp-route-ticketPage="@(Model.TicketsPage - 1)"
                           asp-route-ticketNumbers="@Model.SelectedTicketNumbers">Previous</a>
                        <a class="btn btn-sm btn-outline-secondary @(Model.TicketsPage >= Model.TicketsTotalPages ? "disabled" : null)"
                           asp-page="/Admin/Draws/Edit"
                           asp-route-id="@Model.SelectedDraw.Id"
                           asp-route-ticketPage="@(Model.TicketsPage + 1)"
                           asp-route-ticketNumbers="@Model.SelectedTicketNumbers">Next</a>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.SelectedTicketNumbers))
                {
                    <div class="mt-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">Users with ticket <code>@Model.SelectedTicketNumbers</code></h6>
                            <a class="btn btn-sm btn-outline-secondary"
                               asp-page="/Admin/Draws/Edit"
                               asp-route-id="@Model.SelectedDraw.Id"
                               asp-route-ticketPage="@Model.TicketsPage">Close</a>
                        </div>

                        @if (Model.TicketUsers.Count == 0)
                        {
                            <div class="alert alert-secondary mb-0">No users found for this ticket combination.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                    <tr>
                                        <th>User Id</th>
                                        <th>Telegram User Id</th>
                                        <th>Number</th>
                                        <th>Tickets with this combination</th>
                                        <th>Last bought (UTC)</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var u in Model.TicketUsers)
                                    {
                                        <tr>
                                            <td>@u.UserId</td>
                                            <td>@u.TelegramUserId</td>
                                            <td>@(string.IsNullOrWhiteSpace(u.Number) ? "-" : u.Number)</td>
                                            <td>@u.TicketCount</td>
                                            <td>@u.LastPurchasedAtUtc.ToString("u")</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}



