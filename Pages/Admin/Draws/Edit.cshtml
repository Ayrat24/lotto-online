@page "{id:long}"
@model MiniApp.Pages.Admin.Draws.EditModel
@{
    ViewData["Title"] = Model.T("admin.draws.edit.title", "Edit draw");
}

<h1>@Model.T("admin.draws.edit.heading", "Edit draw")</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

@if (Model.SelectedDraw is null)
{
    <div class="alert alert-warning mt-3">@Model.T("admin.draws.edit.notFound", "Draw not found.")</div>
    <a class="btn btn-secondary" asp-page="/Admin/Draws">@Model.T("admin.draws.edit.back", "Back")</a>
}
else if (Model.CanEdit)
{
    <form method="post" class="mt-3">
        <input type="hidden" name="ticketPage" value="@Model.TicketsPage" />
        <input type="hidden" name="ticketNumbers" value="@Model.SelectedTicketNumbers" />
        <div class="mb-3">
            <label class="form-label">@Model.T("admin.draws.edit.id", "Id")</label>
            <input class="form-control" value="@Model.SelectedDraw.Id" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.draws.edit.state", "State")</label>
            <select asp-for="State" class="form-select">
                <option value="active">@Model.T("admin.draws.edit.state.active", "active")</option>
                <option value="upcoming">@Model.T("admin.draws.edit.state.upcoming", "upcoming")</option>
            </select>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">@Model.T("admin.draws.edit.pool3", "Prize pool 3/5")</label>
                <input asp-for="PrizePoolMatch3" type="number" min="0" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Model.T("admin.draws.edit.pool4", "Prize pool 4/5")</label>
                <input asp-for="PrizePoolMatch4" type="number" min="0" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Model.T("admin.draws.edit.pool5", "Prize pool 5/5")</label>
                <input asp-for="PrizePoolMatch5" type="number" min="0" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Model.T("admin.draws.edit.ticketCost", "Ticket cost")</label>
                <input asp-for="TicketCost" type="number" min="0.01" step="0.01" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="CardColor" class="form-label">@Model.T("admin.draws.edit.cardColor", "Card color")</label>
                <select asp-for="CardColor" class="form-select">
                    @foreach (var option in Model.CardColorOptions)
                    {
                        <option value="@option">@Model.T(MiniApp.Features.Draws.DrawManagement.GetColorDisplayKey(option), option)</option>
                    }
                </select>
                <div class="form-text">@Model.T("admin.draws.edit.cardColorHint", "Used by Mini App draw cards and sorting view.")</div>
            </div>
            <div class="col-md-4">
                <label asp-for="PurchaseClosesAtUtc" class="form-label">@Model.T("admin.draws.edit.purchaseClosesAtUtc", "Ticket sales close at (UTC)")</label>
                <input asp-for="PurchaseClosesAtUtc" type="datetime-local" step="60" class="form-control" />
                <div class="form-text">@Model.T("admin.draws.edit.purchaseClosesAtUtcHint", "Ticket sales stop at this UTC time, but the draw still needs manual execution by admin.")</div>
            </div>
        </div>

        <div class="form-text mt-2">@Model.T("admin.draws.edit.totalPool", "Total pool"): @((Model.PrizePoolMatch3 + Model.PrizePoolMatch4 + Model.PrizePoolMatch5).ToString("0.00"))</div>

        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">@Model.T("admin.draws.edit.save", "Save")</button>
            <a class="btn btn-secondary" asp-page="/Admin/Draws">@Model.T("admin.draws.edit.back", "Back")</a>
        </div>
    </form>

    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">@Model.T("admin.draws.edit.offers.title", "Discounted ticket offers")</h5>
            <p class="text-muted mb-3">@Model.T("admin.draws.edit.offers.subtitle", "Create limited bundle pricing for this draw and connect it to news banners.")</p>

            <form method="post" asp-page-handler="CreateOffer" class="row g-3 align-items-end">
                <input type="hidden" name="ticketPage" value="@Model.TicketsPage" />
                <input type="hidden" name="ticketNumbers" value="@Model.SelectedTicketNumbers" />
                <div class="col-md-4">
                    <label asp-for="OfferNumberOfDiscountedTickets" class="form-label">@Model.T("admin.draws.edit.offers.ticketCount", "Tickets in offer")</label>
                    <input asp-for="OfferNumberOfDiscountedTickets" type="number" min="1" max="50" step="1" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="OfferCost" class="form-label">@Model.T("admin.draws.edit.offers.cost", "Offer cost")</label>
                    <input asp-for="OfferCost" type="number" min="0.01" step="0.01" class="form-control" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-outline-primary w-100">@Model.T("admin.draws.edit.offers.create", "Create discounted offer")</button>
                </div>
            </form>

            <div class="form-text mt-2">@string.Format(Model.T("admin.draws.edit.offers.hint", "Offer cost must be greater than zero and not exceed the regular total of {0} ticket(s) for this draw."), Model.OfferNumberOfDiscountedTickets)</div>

            @if (Model.Offers.Count == 0)
            {
                <div class="alert alert-secondary mt-3 mb-0">@Model.T("admin.draws.edit.offers.empty", "No discounted offers for this draw yet.")</div>
            }
            else
            {
                <div class="table-responsive mt-3">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                        <tr>
                            <th>@Model.T("admin.draws.edit.offers.table.id", "Offer Id")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.ticketCount", "Tickets")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.cost", "Offer cost")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.regularTotal", "Regular total")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.savings", "Savings")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.status", "Status")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.updatedUtc", "Updated (UTC)")</th>
                            <th>@Model.T("admin.draws.edit.offers.table.actions", "Actions")</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var offer in Model.Offers)
                        {
                            <tr>
                                <td><code>@offer.Id</code></td>
                                <td>@offer.NumberOfDiscountedTickets</td>
                                <td><code>@offer.Cost.ToString("0.00")</code></td>
                                <td><code>@offer.RegularTotalCost.ToString("0.00")</code></td>
                                <td>@offer.Savings.ToString("0.00")</td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <span class="badge @(offer.IsActive ? "bg-success-subtle text-dark border border-success-subtle" : "bg-secondary-subtle text-dark border border-secondary-subtle")">
                                            @(offer.IsActive ? Model.T("admin.draws.edit.offers.status.active", "Active") : Model.T("admin.draws.edit.offers.status.inactive", "Inactive"))
                                        </span>
                                        <span class="badge @(offer.IsAvailableNow ? "bg-primary-subtle text-dark border border-primary-subtle" : "bg-warning-subtle text-dark border border-warning-subtle")">
                                            @(offer.IsAvailableNow ? Model.T("admin.draws.edit.offers.status.availableNow", "Available in Mini App") : Model.T("admin.draws.edit.offers.status.unavailableNow", "Not currently available"))
                                        </span>
                                    </div>
                                </td>
                                <td>@offer.UpdatedAtUtc.ToString("u")</td>
                                <td>
                                    <form method="post" asp-page-handler="ToggleOffer" class="d-inline">
                                        <input type="hidden" name="offerId" value="@offer.Id" />
                                        <input type="hidden" name="isActive" value="@(!offer.IsActive)" />
                                        <input type="hidden" name="ticketPage" value="@Model.TicketsPage" />
                                        <input type="hidden" name="ticketNumbers" value="@Model.SelectedTicketNumbers" />
                                        <button type="submit" class="btn btn-sm @(offer.IsActive ? "btn-outline-secondary" : "btn-outline-success")">
                                            @(offer.IsActive ? Model.T("admin.draws.edit.offers.action.deactivate", "Deactivate") : Model.T("admin.draws.edit.offers.action.activate", "Activate"))
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">@Model.T("admin.draws.edit.execute.title", "Execute draw")</h5>
            <p class="text-muted mb-3">@Model.T("admin.draws.edit.execute.subtitle", "You can execute using manual numbers or execute with randomized numbers.")</p>

            @if (Model.State != "active")
            {
                <div class="alert alert-secondary mb-0">@Model.T("admin.draws.edit.execute.activeOnly", "Only active draws can be executed. Set state to active, save, then execute.")</div>
            }
            else
            {
                <form method="post" asp-page-handler="Execute" class="row g-3 align-items-end">
                    <input type="hidden" name="ticketPage" value="@Model.TicketsPage" />
                    <input type="hidden" name="ticketNumbers" value="@Model.SelectedTicketNumbers" />
                    <div class="col-md-6">
                        <label asp-for="ExecuteNumbers" class="form-label">@Model.T("admin.draws.edit.execute.manualNumbers", "Manual result numbers")</label>
                        <input asp-for="ExecuteNumbers" class="form-control" placeholder="@Model.T("admin.draws.edit.execute.placeholder", "1,5,12,23,36")" />
                        <div class="form-text">@Model.T("admin.draws.edit.execute.hint", "Enter 5 unique numbers between 1 and 36 separated by commas.")</div>
                    </div>
                    <div class="col-md-6 d-flex gap-2 flex-wrap">
                        <button type="button" id="randomizePreviewBtn" class="btn btn-outline-secondary">@Model.T("admin.draws.edit.execute.randomize", "Randomize")</button>
                        <button type="submit" class="btn btn-danger" onclick="return confirm('@string.Format(Model.T("admin.draws.edit.execute.confirmManual", "Execute draw #{0} with these numbers?"), Model.SelectedDraw.Id)');">@Model.T("admin.draws.edit.execute.manualSubmit", "Execute with manual numbers")</button>
                        <button type="submit" name="randomize" value="true" class="btn btn-danger" onclick="return confirm('@string.Format(Model.T("admin.draws.edit.execute.confirmRandom", "Execute draw #{0} with randomized numbers?"), Model.SelectedDraw.Id)');">@Model.T("admin.draws.edit.execute.randomSubmit", "Execute randomized")</button>
                    </div>
                </form>
            }
        </div>
    </div>
}
else
{
    <a class="btn btn-secondary mt-3" asp-page="/Admin/Draws">@Model.T("admin.draws.edit.back", "Back")</a>
}

@section Scripts {
    <script>
        (function () {
            var btn = document.getElementById('randomizePreviewBtn');
            var input = document.getElementById('ExecuteNumbers');
            if (!btn || !input) return;

            btn.addEventListener('click', function () {
                var numbers = new Set();
                while (numbers.size < 5) {
                    numbers.add(Math.floor(Math.random() * 36) + 1);
                }

                var arr = Array.from(numbers).sort(function (a, b) { return a - b; });
                input.value = arr.join(',');
            });
        })();
    </script>
}

@if (Model.SelectedDraw is not null)
{
    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">@Model.T("admin.draws.edit.tickets.title", "Bought tickets")</h5>
            <p class="text-muted mb-3">@string.Format(Model.T("admin.draws.edit.tickets.subtitle", "Showing tickets for draw #{0}. Ordered by how often each number set was selected."), Model.SelectedDraw.Id)</p>

            @if (Model.TicketsTotalCount == 0)
            {
                <div class="alert alert-secondary mb-0">@Model.T("admin.draws.edit.tickets.empty", "No tickets bought for this draw yet.")</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                        <tr>
                            <th>@Model.T("admin.draws.edit.tickets.numbers", "Numbers")</th>
                            <th>@Model.T("admin.draws.edit.tickets.count", "Count among all users")</th>
                            <th>@Model.T("admin.draws.edit.tickets.actions", "Actions")</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var t in Model.Tickets)
                        {
                            <tr>
                                <td><code>@t.Numbers</code></td>
                                <td><span class="badge text-bg-light border text-dark">@t.SelectionCount</span></td>
                                <td>
                                    <a class="btn btn-sm @(Model.SelectedTicketNumbers == t.Numbers ? "btn-primary" : "btn-outline-primary")"
                                       asp-page="/Admin/Draws/Edit"
                                       asp-route-id="@Model.SelectedDraw.Id"
                                       asp-route-ticketPage="@Model.TicketsPage"
                                       asp-route-ticketNumbers="@t.Numbers">@Model.T("admin.draws.edit.tickets.users", "Users")</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                    <small class="text-muted">@Model.T("admin.draws.edit.tickets.page", "Page") @Model.TicketsPage @Model.T("admin.draws.edit.tickets.of", "of") @Model.TicketsTotalPages (@Model.TicketsTotalCount @Model.T("admin.draws.edit.tickets.combinations", "combinations"))</small>
                    <div class="btn-group" role="group" aria-label="@Model.T("admin.draws.edit.tickets.paginationAria", "Ticket pagination")">
                        <a class="btn btn-sm btn-outline-secondary @(Model.TicketsPage <= 1 ? "disabled" : null)"
                           asp-page="/Admin/Draws/Edit"
                           asp-route-id="@Model.SelectedDraw.Id"
                           asp-route-ticketPage="@(Model.TicketsPage - 1)"
                           asp-route-ticketNumbers="@Model.SelectedTicketNumbers">@Model.T("admin.draws.edit.tickets.previous", "Previous")</a>
                        <a class="btn btn-sm btn-outline-secondary @(Model.TicketsPage >= Model.TicketsTotalPages ? "disabled" : null)"
                           asp-page="/Admin/Draws/Edit"
                           asp-route-id="@Model.SelectedDraw.Id"
                           asp-route-ticketPage="@(Model.TicketsPage + 1)"
                           asp-route-ticketNumbers="@Model.SelectedTicketNumbers">@Model.T("admin.draws.edit.tickets.next", "Next")</a>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.SelectedTicketNumbers))
                {
                    <div class="mt-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">@Model.T("admin.draws.edit.ticketUsers.title", "Users with ticket") <code>@Model.SelectedTicketNumbers</code></h6>
                            <a class="btn btn-sm btn-outline-secondary"
                               asp-page="/Admin/Draws/Edit"
                               asp-route-id="@Model.SelectedDraw.Id"
                               asp-route-ticketPage="@Model.TicketsPage">@Model.T("admin.draws.edit.ticketUsers.close", "Close")</a>
                        </div>

                        @if (Model.TicketUsers.Count == 0)
                        {
                            <div class="alert alert-secondary mb-0">@Model.T("admin.draws.edit.ticketUsers.empty", "No users found for this ticket combination.")</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                    <tr>
                                        <th>@Model.T("admin.draws.edit.ticketUsers.userId", "User Id")</th>
                                        <th>@Model.T("admin.draws.edit.ticketUsers.telegramUserId", "Telegram User Id")</th>
                                        <th>@Model.T("admin.draws.edit.ticketUsers.number", "Number")</th>
                                        <th>@Model.T("admin.draws.edit.ticketUsers.ticketCount", "Tickets with this combination")</th>
                                        <th>@Model.T("admin.draws.edit.ticketUsers.lastBoughtUtc", "Last bought (UTC)")</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var u in Model.TicketUsers)
                                    {
                                        <tr>
                                            <td>@u.UserId</td>
                                            <td>@u.TelegramUserId</td>
                                            <td>@(string.IsNullOrWhiteSpace(u.Number) ? "-" : u.Number)</td>
                                            <td>@u.TicketCount</td>
                                            <td>@u.LastPurchasedAtUtc.ToString("u")</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}



