@page
@model MiniApp.Pages.Admin.LocalizationModel
@{
    ViewData["Title"] = Model.T("admin.localization.title", "Localization");
}

<h1>@Model.T("admin.localization.title", "Localization")</h1>
<p class="text-muted">@Model.T("admin.localization.subtitle", "Update en / ru / uz UI strings.")</p>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.localization.coverage.title", "Admin localization coverage")</h5>
        @if (Model.AdminCoverageGaps.Count == 0)
        {
            <div class="alert alert-success mb-0">@Model.T("admin.localization.coverage.ok", "All admin keys have en / ru / uz values.")</div>
        }
        else
        {
            <div class="alert alert-warning mb-2">@string.Format(Model.T("admin.localization.coverage.gaps", "Found {0} coverage gap(s)."), Model.AdminCoverageGaps.Count)</div>
            <ul class="mb-0">
                @foreach (var gap in Model.AdminCoverageGaps)
                {
                    <li><code>@gap</code></li>
                }
            </ul>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Toast))
{
    <div class="alert alert-info" role="status">@Model.Toast</div>
}

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
        <tr>
            <th style="width: 20%;">@Model.T("admin.localization.column.key", "Key")</th>
            <th style="width: 24%;">@Model.T("admin.localization.column.english", "English")</th>
            <th style="width: 24%;">@Model.T("admin.localization.column.russian", "Russian")</th>
            <th style="width: 24%;">@Model.T("admin.localization.column.uzbek", "Uzbek")</th>
            <th style="width: 8%;"></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <form method="post" asp-page-handler="Save">
                    <td>
                        <input class="form-control form-control-sm" name="key" value="@item.Key" readonly />
                    </td>
                    <td>
                        <textarea class="form-control form-control-sm" name="englishValue" rows="2">@item.EnglishValue</textarea>
                    </td>
                    <td>
                        <textarea class="form-control form-control-sm" name="russianValue" rows="2">@item.RussianValue</textarea>
                    </td>
                    <td>
                        <textarea class="form-control form-control-sm" name="uzbekValue" rows="2">@item.UzbekValue</textarea>
                    </td>
                    <td>
                        <button class="btn btn-primary btn-sm" type="submit">@Model.T("admin.localization.action.save", "Save")</button>
                    </td>
                </form>
            </tr>
        }
        </tbody>
    </table>
</div>

