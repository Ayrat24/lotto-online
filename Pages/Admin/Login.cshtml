@page
@model MiniApp.Pages.Admin.LoginModel
@{
    ViewData["Title"] = Model.T("admin.login.title", "Admin Login");
}

<h1>@Model.T("admin.login.heading", "Admin Login")</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="mt-3" autocomplete="off">
    <div class="mb-3">
        <label class="form-label">@Model.T("admin.login.username", "Username")</label>
        <input class="form-control" name="Username" value="@Model.Username" />
    </div>

    <div class="mb-3">
        <label class="form-label">@Model.T("admin.login.password", "Password")</label>
        <input class="form-control" type="password" name="Password" />
    </div>

    <button class="btn btn-primary" type="submit">@Model.T("admin.login.submit", "Login")</button>
</form>

