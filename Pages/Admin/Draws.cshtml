@page
@model MiniApp.Pages.Admin.DrawsModel
@{
    ViewData["Title"] = "Draws";
}

<h1>Draws</h1>

<form method="post" asp-page-handler="Start" class="mt-3">
    <button type="submit" class="btn btn-danger">Start Drawing</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info mt-3">@Model.StatusMessage</div>
}

@if (Model.Draws.Count == 0)
{
    <div class="alert alert-secondary mt-3">No draws yet.</div>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Previous draws</h5>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>Id</th>
                        <th>Created (UTC)</th>
                        <th>Numbers</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var d in Model.Draws)
                    {
                        <tr>
                            <td><strong>@d.Id</strong></td>
                            <td>@d.CreatedAtUtc.ToString("u")</td>
                            <td><code>@d.Numbers</code></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
