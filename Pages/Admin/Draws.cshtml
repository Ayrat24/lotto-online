@page
@model MiniApp.Pages.Admin.DrawsModel
@{
    ViewData["Title"] = "Draws";
}

<h1>Draws</h1>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Create draw instance</h5>
        <p class="text-muted mb-3">A new draw becomes <strong>active</strong> when there is no current active draw. Otherwise it is created as <strong>upcoming</strong>.</p>

        <form method="post" asp-page-handler="Create" class="row g-3 align-items-end">
            <div class="col-sm-6 col-md-4">
                <label for="createPrizePoolMatch3" class="form-label">Prize pool 3/5</label>
                <input id="createPrizePoolMatch3" name="prizePoolMatch3" type="number" min="0" step="0.01" value="0" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <label for="createPrizePoolMatch4" class="form-label">Prize pool 4/5</label>
                <input id="createPrizePoolMatch4" name="prizePoolMatch4" type="number" min="0" step="0.01" value="0" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <label for="createPrizePoolMatch5" class="form-label">Prize pool 5/5</label>
                <input id="createPrizePoolMatch5" name="prizePoolMatch5" type="number" min="0" step="0.01" value="0" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <label for="createTicketCost" class="form-label">Ticket cost</label>
                <input id="createTicketCost" name="ticketCost" type="number" min="0.01" step="0.01" value="2" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <button type="submit" class="btn btn-danger w-100">Create draw</button>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

@if (Model.Draws.Count == 0)
{
    <div class="alert alert-secondary mt-3">No draws yet.</div>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Manage draws</h5>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>Id</th>
                        <th>Tickets</th>
                        <th>State</th>
                        <th>Ticket cost</th>
                        <th>Total pool</th>
                        <th>Pools (3/5, 4/5, 5/5)</th>
                        <th>Created (UTC)</th>
                        <th>Numbers</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var d in Model.Draws)
                    {
                        <tr>
                            <td><strong>@d.Id</strong></td>
                            <td>
                                <span class="badge bg-light text-dark border">@d.TicketCount</span>
                            </td>
                            <td>
                                <span class="badge @(d.State == "active" ? "bg-success-subtle text-dark border border-success-subtle" : d.State == "finished" ? "bg-dark text-white" : "bg-secondary-subtle text-dark border border-secondary-subtle") text-uppercase">
                                    @d.State
                                </span>
                            </td>
                            <td><code>@d.TicketCost.ToString("0.00")</code></td>
                            <td>
                                @d.TotalPrizePool.ToString("0.00")
                            </td>
                            <td><code>@d.PrizePoolMatch3.ToString("0.00")</code>, <code>@d.PrizePoolMatch4.ToString("0.00")</code>, <code>@d.PrizePoolMatch5.ToString("0.00")</code></td>
                            <td>@d.CreatedAtUtc.ToString("u")</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(d.Numbers))
                                {
                                    <span class="text-muted">Not executed yet</span>
                                }
                                else
                                {
                                    <code>@d.Numbers</code>
                                }
                            </td>
                            <td>
                                @if (d.State == "active" || d.State == "upcoming")
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Draws/Edit" asp-route-id="@d.Id">Edit</a>
                                }
                                else if (d.State == "finished")
                                {
                                    <a class="btn btn-sm btn-outline-dark" asp-page="/Admin/Draws/Result" asp-route-id="@d.Id">Results</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
