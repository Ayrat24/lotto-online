@page
@model MiniApp.Pages.Admin.DrawsModel
@{
    ViewData["Title"] = Model.T("admin.draws.title", "Draws");
}

<h1 style="margin-bottom:10px;">@Model.T("admin.draws.heading", "Draws")</h1>

<div class="card" style="margin-top:0;">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.draws.purchaseSettings.title", "Ticket purchase screen")</h5>
        <p class="text-muted mb-3">@Model.T("admin.draws.purchaseSettings.subtitle", "Control how many ticket cards the Mini App shows on the new purchase screen.")</p>

        <form method="post" asp-page-handler="SavePurchaseSettings" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-sm-6 col-md-4">
                <label asp-for="TicketSlotsCount" class="form-label">@Model.T("admin.draws.purchaseSettings.ticketSlotsCount", "Ticket cards shown")</label>
                <input asp-for="TicketSlotsCount" class="form-control" type="number" min="1" max="50" step="1" />
            </div>
            <div class="col-sm-6 col-md-4">
                <button type="submit" class="btn btn-outline-primary w-100">@Model.T("admin.draws.purchaseSettings.save", "Save purchase screen")</button>
            </div>
        </form>

        <div class="text-muted small mt-3">
            @Model.T("admin.draws.purchaseSettings.lastUpdated", "Last updated"): @Model.PurchaseSettings.UpdatedAtUtc.ToString("u") @Model.T("admin.draws.purchaseSettings.by", "by") @(string.IsNullOrWhiteSpace(Model.PurchaseSettings.UpdatedByAdmin) ? "-" : Model.PurchaseSettings.UpdatedByAdmin)
        </div>
    </div>
</div>

<div class="card" style="margin-top:0;">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.draws.create.title", "Create draw instance")</h5>
        <p class="text-muted mb-3">@Model.T("admin.draws.create.subtitle", "A new draw is created as active. Multiple active draws can run at the same time.")</p>

        <form method="post" asp-page-handler="Create" class="row g-2 align-items-end">
            <div class="col-sm-6 col-md-4">
                <label for="createPrizePoolMatch3" class="form-label">@Model.T("admin.draws.create.pool3", "Prize pool 3/5")</label>
                <input id="createPrizePoolMatch3" name="prizePoolMatch3" type="number" min="0" step="0.01" value="0" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <label for="createPrizePoolMatch4" class="form-label">@Model.T("admin.draws.create.pool4", "Prize pool 4/5")</label>
                <input id="createPrizePoolMatch4" name="prizePoolMatch4" type="number" min="0" step="0.01" value="0" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <label for="createPrizePoolMatch5" class="form-label">@Model.T("admin.draws.create.pool5", "Prize pool 5/5")</label>
                <input id="createPrizePoolMatch5" name="prizePoolMatch5" type="number" min="0" step="0.01" value="0" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <label for="createTicketCost" class="form-label">@Model.T("admin.draws.create.ticketCost", "Ticket cost")</label>
                <input id="createTicketCost" name="ticketCost" type="number" min="0.01" step="0.01" value="2" class="form-control" />
            </div>
            <div class="col-sm-6 col-md-4">
                <button type="submit" class="btn btn-danger w-100">@Model.T("admin.draws.create.submit", "Create draw")</button>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info")" style="margin-top:10px;">@Model.StatusMessage</div>
}

@if (Model.Draws.Count == 0)
{
    <div class="alert alert-secondary" style="margin-top:10px;">@Model.T("admin.draws.empty", "No draws yet.")</div>
}
else
{
    <div class="card" style="margin-top:10px;">
        <div class="card-body">
            <h5 class="card-title">@Model.T("admin.draws.manage.title", "Manage draws")</h5>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>@Model.T("admin.draws.table.id", "Id")</th>
                        <th>@Model.T("admin.draws.table.tickets", "Tickets")</th>
                        <th>@Model.T("admin.draws.table.state", "State")</th>
                        <th>@Model.T("admin.draws.table.ticketCost", "Ticket cost")</th>
                        <th>@Model.T("admin.draws.table.totalPool", "Total pool")</th>
                        <th>@Model.T("admin.draws.table.pools", "Pools (3/5, 4/5, 5/5)")</th>
                        <th>@Model.T("admin.draws.table.createdUtc", "Created (UTC)")</th>
                        <th>@Model.T("admin.draws.table.numbers", "Numbers")</th>
                        <th>@Model.T("admin.draws.table.actions", "Actions")</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var d in Model.Draws)
                    {
                        <tr>
                            <td><strong>@d.Id</strong></td>
                            <td>
                                <span class="badge bg-light text-dark border">@d.TicketCount</span>
                            </td>
                            <td>
                                <span class="badge @(d.State == "active" ? "bg-success-subtle text-dark border border-success-subtle" : d.State == "finished" ? "bg-dark text-white" : "bg-secondary-subtle text-dark border border-secondary-subtle") text-uppercase">
                                    @d.State
                                </span>
                            </td>
                            <td><code>@d.TicketCost.ToString("0.00")</code></td>
                            <td>
                                @d.TotalPrizePool.ToString("0.00")
                            </td>
                            <td><code>@d.PrizePoolMatch3.ToString("0.00")</code>, <code>@d.PrizePoolMatch4.ToString("0.00")</code>, <code>@d.PrizePoolMatch5.ToString("0.00")</code></td>
                            <td>@d.CreatedAtUtc.ToString("u")</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(d.Numbers))
                                {
                                    <span class="text-muted">@Model.T("admin.draws.table.notExecuted", "Not executed yet")</span>
                                }
                                else
                                {
                                    <code>@d.Numbers</code>
                                }
                            </td>
                            <td>
                                @if (d.State == "active" || d.State == "upcoming")
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Draws/Edit" asp-route-id="@d.Id">@Model.T("admin.draws.action.edit", "Edit")</a>
                                }
                                else if (d.State == "finished")
                                {
                                    <a class="btn btn-sm btn-outline-dark" asp-page="/Admin/Draws/Result" asp-route-id="@d.Id">@Model.T("admin.draws.action.results", "Results")</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
