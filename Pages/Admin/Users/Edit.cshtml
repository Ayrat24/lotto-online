@page "{id:long}"
@model MiniApp.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = Model.T("admin.users.edit.title", "Edit user");
}

<h1>@Model.T("admin.users.edit.heading", "Edit user")</h1>

@if (Model.SelectedUser is null)
{
    <div class="alert alert-warning">@Model.T("admin.users.edit.userNotFound", "User not found.")</div>
}
else
{
    <form method="post" class="mt-3">
        <input type="hidden" asp-for="SearchPhone" />
        <input type="hidden" asp-for="SearchTelegramId" />
        <input type="hidden" asp-for="SearchDeepLink" />
        <input type="hidden" asp-for="SortBy" />
        <input type="hidden" asp-for="SortDir" />
        <input type="hidden" asp-for="PageNumber" />
        <input type="hidden" asp-for="PageSize" />

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.id", "Id")</label>
            <input class="form-control" value="@Model.SelectedUser.Id" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.telegramUserId", "TelegramUserId")</label>
            <input class="form-control" asp-for="TelegramUserId" />
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.number", "Number")</label>
            <input class="form-control" asp-for="Number" />
            <div class="form-text">@Model.T("admin.users.edit.numberHint", "Collected from Telegram contact share on /start.")</div>
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.deepLink", "Acquisition deep link")</label>
            <input class="form-control" asp-for="AcquisitionDeepLink" />
            <div class="form-text">@Model.T("admin.users.edit.deepLinkHint", "Stored from Telegram /start payload or Mini App initData start_param.")</div>
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.balance", "Balance")</label>
            <input class="form-control" asp-for="Balance" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.createdAtUtc", "CreatedAtUtc")</label>
            <input class="form-control" value="@Model.SelectedUser.CreatedAtUtc" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">@Model.T("admin.users.edit.lastSeenAtUtc", "LastSeenAtUtc")</label>
            <input class="form-control" asp-for="LastSeenAtUtc" />
        </div>

        <button class="btn btn-primary" type="submit">@Model.T("admin.users.edit.save", "Save")</button>
        <a class="btn btn-secondary"
           asp-page="/Admin/Users/Index"
           asp-route-searchPhone="@Model.SearchPhone"
           asp-route-searchTelegramId="@Model.SearchTelegramId"
           asp-route-searchDeepLink="@Model.SearchDeepLink"
           asp-route-sortBy="@Model.SortBy"
           asp-route-sortDir="@Model.SortDir"
           asp-route-pageNumber="@Model.PageNumber"
           asp-route-pageSize="@Model.PageSize">@Model.T("admin.users.edit.back", "Back")</a>
    </form>
}
