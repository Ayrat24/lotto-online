@page "{id:long}"
@model MiniApp.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Edit user";
}

<h1>Edit user</h1>

@if (Model.SelectedUser is null)
{
    <div class="alert alert-warning">User not found.</div>
}
else
{
    <form method="post" class="mt-3">
        <div class="mb-3">
            <label class="form-label">Id</label>
            <input class="form-control" value="@Model.SelectedUser.Id" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">TelegramUserId</label>
            <input class="form-control" asp-for="TelegramUserId" />
        </div>

        <div class="mb-3">
            <label class="form-label">Number</label>
            <input class="form-control" asp-for="Number" />
            <div class="form-text">Collected from Telegram contact share on /start.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Acquisition deep link</label>
            <input class="form-control" asp-for="AcquisitionDeepLink" />
            <div class="form-text">Stored from Telegram /start payload or Mini App initData start_param.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Balance</label>
            <input class="form-control" asp-for="Balance" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label class="form-label">CreatedAtUtc</label>
            <input class="form-control" value="@Model.SelectedUser.CreatedAtUtc" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">LastSeenAtUtc</label>
            <input class="form-control" asp-for="LastSeenAtUtc" />
        </div>

        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-secondary" asp-page="/Admin/Users/Index">Back</a>
    </form>
}
