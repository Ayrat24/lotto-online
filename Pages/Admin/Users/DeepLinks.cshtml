@page
@model MiniApp.Pages.Admin.Users.DeepLinksModel
@{
	ViewData["Title"] = "Deep-link analytics";
}

<h1>Deep-link analytics</h1>

<div class="mt-2 d-flex gap-2">
	<a class="btn btn-sm btn-outline-secondary"
	   asp-page="/Admin/Users/Index"
	   asp-route-searchPhone="@Model.SearchPhone"
	   asp-route-searchTelegramId="@Model.SearchTelegramId"
	   asp-route-searchDeepLink="@Model.SearchDeepLink"
	   asp-route-sortBy="@Model.SortBy"
	   asp-route-sortDir="@Model.SortDir"
	   asp-route-pageNumber="@Model.PageNumber"
	   asp-route-pageSize="@Model.PageSize">Back to users</a>
</div>

@if (Model.Rows.Count == 0)
{
	<div class="alert alert-secondary mt-3">No users found.</div>
}
else
{
	<div class="table-responsive mt-3">
		<table class="table table-striped align-middle mb-0">
			<thead>
			<tr>
				<th>Deep link</th>
				<th>User Count</th>
			</tr>
			</thead>
			<tbody>
			@foreach (var row in Model.Rows)
			{
				<tr>
					<td><code>@row.DeepLink</code></td>
					<td>@row.UserCount</td>
				</tr>
			}
			</tbody>
		</table>
	</div>
}

