@page
@model MiniApp.Pages.Admin.Users.DeepLinksModel
@{
	ViewData["Title"] = Model.T("admin.users.deepLinks.title", "Deep-link analytics");
}

<h1>@Model.T("admin.users.deepLinks.heading", "Deep-link analytics")</h1>

<div class="mt-2 d-flex gap-2">
	<a class="btn btn-sm btn-outline-secondary"
	   asp-page="/Admin/Users/Index"
	   asp-route-searchPhone="@Model.SearchPhone"
	   asp-route-searchTelegramId="@Model.SearchTelegramId"
	   asp-route-searchDeepLink="@Model.SearchDeepLink"
	   asp-route-sortBy="@Model.SortBy"
	   asp-route-sortDir="@Model.SortDir"
	   asp-route-pageNumber="@Model.PageNumber"
	   asp-route-pageSize="@Model.PageSize">@Model.T("admin.users.deepLinks.backToUsers", "Back to users")</a>
</div>

@if (Model.Rows.Count == 0)
{
	<div class="alert alert-secondary mt-3">@Model.T("admin.users.deepLinks.empty", "No users found.")</div>
}
else
{
	<div class="table-responsive mt-3">
		<table class="table table-striped align-middle mb-0">
			<thead>
			<tr>
				<th>@Model.T("admin.users.deepLinks.table.deepLink", "Deep link")</th>
				<th>@Model.T("admin.users.deepLinks.table.userCount", "User Count")</th>
			</tr>
			</thead>
			<tbody>
			@foreach (var row in Model.Rows)
			{
				<tr>
					<td><code>@row.DeepLink</code></td>
					<td>@row.UserCount</td>
				</tr>
			}
			</tbody>
		</table>
	</div>
}

