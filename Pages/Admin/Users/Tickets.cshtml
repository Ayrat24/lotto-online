@page "{id:long}/Tickets"
@model MiniApp.Pages.Admin.Users.TicketsModel
@{
    ViewData["Title"] = Model.Text("admin.users.tickets.title", "User tickets");
}

<h1>@Model.Text("admin.users.tickets.title", "User tickets")</h1>

<div class="mb-3">
    <a class="btn btn-sm btn-outline-secondary"
       asp-page="/Admin/Users/Index"
       asp-route-searchPhone="@Model.SearchPhone"
       asp-route-searchTelegramId="@Model.SearchTelegramId"
       asp-route-searchDeepLink="@Model.SearchDeepLink"
       asp-route-sortBy="@Model.SortBy"
       asp-route-sortDir="@Model.SortDir"
       asp-route-pageNumber="@Model.PageNumber"
        asp-route-pageSize="@Model.PageSize">@Model.Text("admin.users.tickets.backToUsers", "Back to users")</a>
</div>

@if (Model.SelectedUser is null)
{
    <div class="alert alert-warning">@Model.Text("admin.users.tickets.userNotFound", "User not found.")</div>
    return;
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info")">@Model.StatusMessage</div>
}

<div class="card mb-3">
    <div class="card-body">
        <div><strong>@Model.Text("admin.users.tickets.userId", "User Id"):</strong> @Model.SelectedUser.Id</div>
        <div><strong>@Model.Text("admin.users.tickets.telegramUserId", "TelegramUserId"):</strong> @Model.SelectedUser.TelegramUserId</div>
        <div><strong>@Model.Text("admin.users.tickets.balance", "Balance"):</strong> @Model.SelectedUser.Balance.ToString("0.00")</div>
        <div><strong>@Model.Text("admin.users.tickets.created", "Created"):</strong> @Model.SelectedUser.CreatedAtUtc</div>
        <div><strong>@Model.Text("admin.users.tickets.lastSeen", "Last seen"):</strong> @Model.SelectedUser.LastSeenAtUtc</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5">@Model.Text("admin.users.tickets.addTitle", "Add ticket")</h2>

        @if (Model.Draws.Count == 0)
        {
            <div class="alert alert-secondary mb-0">@Model.Text("admin.users.tickets.noDraws", "No draws found. Create a draw first.")</div>
        }
        else
        {
            <form method="post" asp-page-handler="AddTicket" asp-route-id="@Model.SelectedUser.Id" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SearchPhone" />
                <input type="hidden" asp-for="SearchTelegramId" />
                <input type="hidden" asp-for="SearchDeepLink" />
                <input type="hidden" asp-for="SortBy" />
                <input type="hidden" asp-for="SortDir" />
                <input type="hidden" asp-for="PageNumber" />
                <input type="hidden" asp-for="PageSize" />

                <div class="col-md-4">
                    <label asp-for="SelectedDrawId" class="form-label">@Model.Text("admin.users.tickets.draw", "Draw")</label>
                    <select asp-for="SelectedDrawId" class="form-select">
                        @foreach (var draw in Model.Draws)
                        {
                            <option value="@draw.Id">#@draw.Id (@draw.State)</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="TicketNumbers" class="form-label">@Model.Text("admin.users.tickets.numbers", "Numbers")</label>
                    <input asp-for="TicketNumbers" class="form-control" placeholder="@Model.Text("admin.users.tickets.numbersPlaceholder", "e.g. 1,7,14,23,36")" />
                </div>

                <div class="col-auto">
                    <button class="btn btn-primary" type="submit">@Model.Text("admin.users.tickets.addButton", "Add ticket")</button>
                </div>

                <div class="col-12 text-muted small">
                    @Model.Text("admin.users.tickets.hint", "Enter exactly 5 unique numbers from 1 to 36, separated by commas.")
                </div>
            </form>
        }
    </div>
</div>

<h2>@Model.Text("admin.users.tickets.listTitle", "Tickets") (@Model.Tickets.Count)</h2>

@if (Model.Tickets.Count == 0)
{
    <div class="muted">@Model.Text("admin.users.tickets.empty", "No tickets yet.")</div>
}
else
{
    <div class="table-responsive mt-3">
        <table class="table table-striped align-middle mb-0">
            <thead>
            <tr>
                <th>@Model.Text("admin.users.tickets.id", "Id")</th>
                <th>@Model.Text("admin.users.tickets.drawId", "DrawId")</th>
                <th>@Model.Text("admin.users.tickets.numbers", "Numbers")</th>
                <th>@Model.Text("admin.users.tickets.status", "Status")</th>
                <th>@Model.Text("admin.users.tickets.purchasedUtc", "Purchased (UTC)")</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var t in Model.Tickets)
            {
                <tr>
                    <td>@t.Id</td>
                    <td><strong>@t.DrawId</strong></td>
                    <td><code>@t.Numbers</code></td>
                    <td>@t.Status</td>
                    <td>@t.PurchasedAtUtc</td>
                    <td class="text-end">
                        <form method="post" asp-page-handler="DeleteTicket" asp-route-id="@Model.SelectedUser.Id" asp-route-ticketId="@t.Id"
                              onsubmit="return confirm('@Model.Text("admin.users.tickets.confirmDelete", "Delete this ticket?")');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="SearchPhone" />
                            <input type="hidden" asp-for="SearchTelegramId" />
                            <input type="hidden" asp-for="SearchDeepLink" />
                            <input type="hidden" asp-for="SortBy" />
                            <input type="hidden" asp-for="SortDir" />
                            <input type="hidden" asp-for="PageNumber" />
                            <input type="hidden" asp-for="PageSize" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">@Model.Text("admin.users.tickets.delete", "Delete")</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
