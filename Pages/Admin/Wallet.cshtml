@page
@model MiniApp.Pages.Admin.WalletModel
@{
    ViewData["Title"] = Model.T("admin.wallet.title", "Wallet");
}

<h1>@Model.T("admin.wallet.heading", "Wallet")</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-info") mt-3">@Model.StatusMessage</div>
}

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.wallet.serverBalance", "Server balance")</h5>
        <div class="display-6">@Model.ServerBalance.ToString("0.00")</div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.wallet.withdrawals.pendingTitle", "Withdrawal requests")</h5>

        @if (Model.PendingWithdrawalRequests.Count == 0)
        {
            <div class="alert alert-secondary">@Model.T("admin.wallet.withdrawals.pendingEmpty", "No pending withdrawal requests.")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>@Model.T("admin.wallet.table.id", "Id")</th>
                        <th>@Model.T("admin.wallet.table.user", "User")</th>
                        <th>@Model.T("admin.wallet.table.amount", "Amount")</th>
                        <th>@Model.T("admin.wallet.table.number", "Number")</th>
                        <th>@Model.T("admin.wallet.table.createdUtc", "Created (UTC)")</th>
                        <th>@Model.T("admin.wallet.table.actions", "Actions")</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var wr in Model.PendingWithdrawalRequests)
                    {
                        <tr>
                            <td>@wr.Id</td>
                            <td><code>@wr.UserId</code> / <code>@wr.TelegramUserId</code></td>
                            <td>@wr.Amount.ToString("0.00")</td>
                            <td><code>@wr.Number</code></td>
                            <td>@wr.CreatedAtUtc.ToString("u")</td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <form method="post" asp-page-handler="ConfirmWithdrawal" asp-route-id="@wr.Id" onsubmit="return confirm('@string.Format(Model.T("admin.wallet.confirm.confirmPrompt", "Confirm withdrawal request #{0}?"), wr.Id)');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-success" type="submit">@Model.T("admin.wallet.action.confirm", "Confirm")</button>
                                    </form>
                                    <form method="post" asp-page-handler="DenyWithdrawal" asp-route-id="@wr.Id" class="d-flex gap-2" onsubmit="return confirm('@string.Format(Model.T("admin.wallet.confirm.denyPrompt", "Deny withdrawal request #{0} and refund user?"), wr.Id)');">
                                        @Html.AntiForgeryToken()
                                        <input type="text" name="note" class="form-control form-control-sm" placeholder="@Model.T("admin.wallet.notePlaceholder", "Optional note")" maxlength="256" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">@Model.T("admin.wallet.action.deny", "Deny")</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.wallet.withdrawals.historyTitle", "Recent withdrawal history")</h5>

        @if (Model.RecentWithdrawalRequests.Count == 0)
        {
            <div class="alert alert-secondary mb-0">@Model.T("admin.wallet.withdrawals.historyEmpty", "No withdrawal requests yet.")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>@Model.T("admin.wallet.table.id", "Id")</th>
                        <th>@Model.T("admin.wallet.table.user", "User")</th>
                        <th>@Model.T("admin.wallet.table.amount", "Amount")</th>
                        <th>@Model.T("admin.wallet.table.number", "Number")</th>
                        <th>@Model.T("admin.wallet.table.status", "Status")</th>
                        <th>@Model.T("admin.wallet.table.createdUtc", "Created (UTC)")</th>
                        <th>@Model.T("admin.wallet.table.reviewedUtc", "Reviewed (UTC)")</th>
                        <th>@Model.T("admin.wallet.table.admin", "Admin")</th>
                        <th>@Model.T("admin.wallet.table.note", "Note")</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var wr in Model.RecentWithdrawalRequests)
                    {
                        <tr>
                            <td>@wr.Id</td>
                            <td><code>@wr.UserId</code> / <code>@wr.TelegramUserId</code></td>
                            <td>@wr.Amount.ToString("0.00")</td>
                            <td><code>@wr.Number</code></td>
                            <td>@wr.Status</td>
                            <td>@wr.CreatedAtUtc.ToString("u")</td>
                            <td>@(wr.ReviewedAtUtc?.ToString("u") ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(wr.ReviewedByAdmin) ? "-" : wr.ReviewedByAdmin)</td>
                            <td>@(string.IsNullOrWhiteSpace(wr.ReviewNote) ? "-" : wr.ReviewNote)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.T("admin.wallet.transactions.title", "Transaction history")</h5>

        @if (Model.Transactions.Count == 0)
        {
            <div class="alert alert-secondary mb-0">@Model.T("admin.wallet.transactions.empty", "No wallet transactions yet.")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>@Model.T("admin.wallet.transactions.timeUtc", "Time (UTC)")</th>
                        <th>@Model.T("admin.wallet.transactions.type", "Type")</th>
                        <th>@Model.T("admin.wallet.table.user", "User")</th>
                        <th>@Model.T("admin.wallet.transactions.userDelta", "User delta")</th>
                        <th>@Model.T("admin.wallet.transactions.userBalanceAfter", "User balance after")</th>
                        <th>@Model.T("admin.wallet.transactions.serverDelta", "Server delta")</th>
                        <th>@Model.T("admin.wallet.transactions.serverBalanceAfter", "Server balance after")</th>
                        <th>@Model.T("admin.wallet.transactions.reference", "Reference")</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var tx in Model.Transactions)
                    {
                        <tr>
                            <td>@tx.CreatedAtUtc.ToString("u")</td>
                            <td>@tx.Type</td>
                            <td><code>@tx.UserId</code> / <code>@tx.TelegramUserId</code></td>
                            <td>@tx.UserDelta.ToString("0.00")</td>
                            <td>@tx.UserBalanceAfter.ToString("0.00")</td>
                            <td>@tx.ServerDelta.ToString("0.00")</td>
                            <td>@tx.ServerBalanceAfter.ToString("0.00")</td>
                            <td>@(string.IsNullOrWhiteSpace(tx.Reference) ? "-" : tx.Reference)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>


