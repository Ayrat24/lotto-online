@page
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lotto Mini App</title>

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="/css/miniapp.css" />
</head>
<body>
  <main class="container stack">
    <header>
      <h1>Lotto</h1>
      <p id="info" class="muted"></p>
    </header>

    <section class="card stack">
      <div class="row">
        <button id="purchaseTicketBtn" type="button">Purchase Ticket</button>
        <button id="closeBtn" type="button" class="secondary">Close</button>
      </div>
      <div id="purchaseStatus" class="muted"></div>
    </section>

    <section class="card">
      <div class="ticket-header">
        <div class="ticket-title">Your tickets</div>
        <div id="ticketsCount" class="ticket-meta"></div>
      </div>
      <div id="ticketsEmpty" class="muted">No tickets yet.</div>
      <ul id="ticketsList"></ul>
    </section>
  </main>

  <script src="/js/miniapp.js"></script>
</body>
</html>
