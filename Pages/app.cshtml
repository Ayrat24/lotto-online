@page
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lotto</title>

  <!-- Use sandy-brown as system/browser theme color -->
  <meta name="theme-color" content="#ee964b" />
  <meta name="msapplication-navbutton-color" content="#ee964b" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <script src="/lib/signalr/signalr.min.js"></script>
  <link rel="stylesheet" href="/css/miniapp.css" />
</head>
<body>
  <main class="container stack">
    <div class="banner card">
      <div class="banner-inner">
        <div class="banner-title">Get lucky, win a trillion humster coins!</div>
      </div>
    </div>

    <section class="card stack">
      <button id="purchaseTicketBtn" type="button">Purchase Ticket</button>
      <div id="purchaseStatus" class="muted"></div>
    </section>

    <div class="ticket-header">
      <div class="ticket-title">Draws</div>
      <div id="timelineStatus" class="ticket-meta"></div>
    </div>
    <div id="timelineEmpty" class="muted">No draws yet. Ask admin to start a draw.</div>
    <ul id="timelineList"></ul>
  </main>

  <script src="/js/miniapp.js"></script>
</body>
</html>
