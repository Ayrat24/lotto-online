@page
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lotto</title>

  <!-- Control the browser/OS top bar color (varies by platform) -->
  <meta name="theme-color" content="#083d77" />
  <meta name="msapplication-navbutton-color" content="#083d77" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="/css/miniapp.css" />
</head>
<body>
  <main class="container stack">
    <section class="card stack">
      <button id="purchaseTicketBtn" type="button">Purchase Ticket</button>
      <div id="purchaseStatus" class="muted"></div>
    </section>

    <section class="card">
      <div class="ticket-header">
        <div class="ticket-title">Tickets</div>
        <div id="ticketsCount" class="ticket-meta"></div>
      </div>
      <div id="ticketsEmpty" class="muted">No tickets yet.</div>
      <ul id="ticketsList"></ul>
    </section>
  </main>

  <script src="/js/miniapp.js"></script>
</body>
</html>
