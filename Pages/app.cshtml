@page
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title data-loc="client.app.title">Lotto</title>

  <meta name="theme-color" content="#0b1019" />
  <meta name="msapplication-navbutton-color" content="#0b1019" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="~/css/miniapp.css" asp-append-version="true" />
</head>
<body class="app-loading">
  <div id="appLoadingShell" class="loading-shell" aria-hidden="true">
    <div class="container loading-shell-inner">
      <div class="loading-shell-topbar">
        <div class="loading-skeleton loading-skeleton-circle"></div>
        <div class="loading-skeleton loading-skeleton-title"></div>
      </div>

      <section class="loading-shell-card loading-shell-hero">
        <div class="loading-shell-row">
          <div class="loading-skeleton loading-skeleton-chip"></div>
          <div class="loading-skeleton loading-skeleton-time"></div>
        </div>
        <div class="loading-skeleton loading-skeleton-amount"></div>
        <div class="loading-skeleton loading-skeleton-copy"></div>
        <div class="loading-shell-pills">
          <div class="loading-skeleton loading-skeleton-pill"></div>
          <div class="loading-skeleton loading-skeleton-pill"></div>
          <div class="loading-skeleton loading-skeleton-pill"></div>
        </div>
      </section>

      <section class="loading-shell-card loading-shell-main">
        <div class="loading-shell-row">
          <div class="loading-skeleton loading-skeleton-title loading-skeleton-title-sm"></div>
          <div class="loading-skeleton loading-skeleton-badge"></div>
        </div>
        <div class="loading-skeleton loading-skeleton-line"></div>
        <div class="loading-skeleton loading-skeleton-button"></div>
        <div class="loading-skeleton loading-skeleton-line loading-skeleton-line-wide"></div>
      </section>

      <section class="loading-shell-card loading-shell-list">
        <div class="loading-shell-row">
          <div class="loading-skeleton loading-skeleton-title loading-skeleton-title-sm"></div>
          <div class="loading-skeleton loading-skeleton-badge"></div>
        </div>
        <div class="loading-skeleton loading-skeleton-ticket"></div>
        <div class="loading-skeleton loading-skeleton-ticket"></div>
      </section>

      <nav class="loading-shell-tabbar" aria-label="Loading tabs" data-loc-aria-label="client.loading.tabsAria">
        <div class="loading-skeleton loading-skeleton-tab"></div>
        <div class="loading-skeleton loading-skeleton-tab"></div>
        <div class="loading-skeleton loading-skeleton-tab"></div>
        <div class="loading-skeleton loading-skeleton-tab"></div>
      </nav>
    </div>
  </div>

  <header class="app-fixed-header" aria-label="App header" data-loc-aria-label="client.header.aria">
    <div class="app-fixed-header-inner">
      <div class="brand">
        <div class="brand-icon">⚡</div>
        <div class="brand-title" data-loc="client.brand.title">LottoVibe</div>
      </div>
      <div class="balance-block">
        <div class="balance-label" data-loc="client.balance.label">Money</div>
        <div id="userBalanceText" class="balance-value">$0.00</div>
      </div>
    </div>
  </header>

  <main id="appShell" class="container app-shell" aria-busy="true">
    <section id="lotteryTabPanel" class="tab-panel stack">

      <div id="debugModeBadge" class="debug-mode-badge" hidden></div>

      <section id="newsBannerSection" class="card news-banner-section" hidden>
        <div class="section-header news-banner-header">
          <div class="section-title news-banner-title" data-loc="client.news.title">Latest news</div>
        </div>
        <div id="newsBannerCarousel" class="news-banner-carousel" aria-label="News banners" data-loc-aria-label="client.news.carouselAria">
          <div id="newsBannerTrack" class="news-banner-track"></div>
          <div id="newsBannerDots" class="news-banner-dots"></div>
        </div>
      </section>

      <section id="featuredJackpotCard" class="card draw-card featured-draw-card">
        <div class="draw-card-header">
          <div id="jackpotGameTitle" class="draw-card-title" data-loc="client.drawCard.titlePrefix">Draw #</div>
          <div id="currentDrawCreatedAt" class="draw-card-timer" data-loc="client.jackpot.endsIn">Ends in --:--:--</div>
        </div>

        <div id="currentDrawStateBadge" class="draw-card-status" hidden></div>
        <div id="jackpotSubtitle" class="draw-card-jackpot-label" data-loc="client.drawCard.jackpotLabel">JACKPOT</div>
        <div id="jackpotAmount" class="draw-card-jackpot-value">$0.00</div>

        <div class="draw-card-footer">
          <div class="draw-card-cost-block">
            <div class="draw-card-cost-label" data-loc="client.drawCard.ticketCostLabel">Ticket cost</div>
            <div id="jackpotBuyPrice" class="draw-card-cost-value">$2.00</div>
          </div>
        </div>

        <div id="currentDrawPrizeTiers" hidden>
          <span id="currentDrawPrizePool3">$0.00</span>
          <span id="currentDrawPrizePool4">$0.00</span>
          <span id="currentDrawPrizePool5">$0.00</span>
        </div>
      </section>

      <section id="drawSortTabsSection" class="draw-sort-tabs-section" hidden>
        <div class="draw-sort-tabs" role="tablist" aria-label="Draw sorting" data-loc-aria-label="client.drawSort.aria">
          <button id="sortClosestDrawBtn" type="button" class="draw-sort-tab draw-sort-tab-active" role="tab" aria-selected="true" data-loc="client.drawSort.closest">Closest draw</button>
          <button id="sortBiggestJackpotBtn" type="button" class="draw-sort-tab" role="tab" aria-selected="false" data-loc="client.drawSort.biggestJackpot">Biggest jackpot</button>
          <button id="sortCheaperTicketsBtn" type="button" class="draw-sort-tab" role="tab" aria-selected="false" data-loc="client.drawSort.cheaperTickets">Cheaper tickets</button>
        </div>
      </section>

      <div id="jackpotCardsContainer" class="stack" hidden></div>

      <div id="purchaseStatus" class="section-subtitle"></div>

      <!-- current draw card removed — its small helpers were migrated into the jackpot card above -->

    </section>

    <section id="ticketsTabPanel" class="tab-panel stack" hidden>
      <div class="card stack">
        <div class="section-header tickets-header">
          <div class="section-title" data-loc="client.tickets.title">My tickets</div>
        </div>
        <div id="timelineStatus" class="section-subtitle"></div>
        <div id="myTicketsEmpty" class="empty-card" data-loc="client.tickets.empty">You have not bought any tickets yet.</div>
        <div id="myTicketsList" class="history-list"></div>
      </div>
    </section>

    <section id="winnersTabPanel" class="tab-panel stack" hidden>
      <div class="card stack winners-screen">
        <div class="section-header">
          <div class="section-title" data-loc="client.winners.title">Winners</div>
        </div>
        <div id="winnersStatus" class="section-subtitle"></div>
        <div id="winnersEmpty" class="empty-card" data-loc="client.winners.empty">Winners will appear here soon.</div>
        <div id="winnersList" class="winners-list"></div>
      </div>
    </section>

    <section id="profileTabPanel" class="tab-panel stack" hidden>
      <div id="profileHomeScreen" class="card stack profile-screen">
        <div class="section-title" data-loc="client.profile.title">Profile</div>

        <button id="openDepositScreenBtn" type="button" data-loc="client.profile.menuDeposit">Deposit Money</button>
        <button id="openInviteScreenBtn" type="button" class="secondary-btn" data-loc="client.profile.menuInvite">Invite Friend</button>
        <button id="openWithdrawScreenBtn" type="button" class="secondary-btn" data-loc="client.profile.menuWithdraw">Withdraw Money</button>
        <button id="openHistoryScreenBtn" type="button" class="secondary-btn" data-loc="client.profile.menuHistory">Transaction History</button>
      </div>

      <div id="profileDepositScreen" class="card stack profile-screen" hidden>
        <button id="backFromDepositBtn" type="button" class="profile-back-btn" data-loc-aria-label="client.button.back">←</button>
        <div class="section-header">
          <div class="section-title" data-loc="client.profile.menuDeposit">Deposit Money</div>
        </div>
        <input id="topUpAmountInput" type="number" min="0.01" step="0.01" placeholder="Top up amount" data-loc-placeholder="client.topup.amountPlaceholder" class="profile-input" />
        <div class="section-subtitle" data-loc="client.topup.methodTitle">Choose payment method</div>
        <div id="paymentSystemsHint" class="muted" data-loc="client.topup.methodHint">Use Telegram Wallet for native TON transfers or BTCPay for external crypto checkout.</div>
        <div id="paymentSystemsList" class="payment-systems-list"></div>
        <button id="topUpBtn" type="button" data-loc="client.button.deposit">Add funds</button>
        <div id="topUpStatus" class="muted"></div>

        <section id="depositDetailsCard" class="deposit-details-card" hidden>
          <div class="section-header">
            <div class="section-title deposit-details-title" data-loc="client.topup.detailsTitle">Payment details</div>
          </div>
          <div class="deposit-details-grid">
            <div class="deposit-details-row">
              <span class="deposit-details-label" data-loc="client.topup.detailsAmount">Amount to send</span>
              <strong id="depositDetailsAmount" class="deposit-details-value">-</strong>
            </div>
            <div class="deposit-details-row">
              <span class="deposit-details-label" data-loc="client.topup.detailsAddress">Destination wallet</span>
              <strong id="depositDetailsAddress" class="deposit-details-value">-</strong>
            </div>
            <div class="deposit-details-row">
              <span class="deposit-details-label" data-loc="client.topup.detailsMemo">Memo / comment</span>
              <strong id="depositDetailsMemo" class="deposit-details-value">-</strong>
            </div>
            <div class="deposit-details-row">
              <span class="deposit-details-label" data-loc="client.topup.detailsTx">Transaction id</span>
              <strong id="depositDetailsTx" class="deposit-details-value">-</strong>
            </div>
          </div>
          <div class="deposit-details-actions">
            <button id="openDepositWalletBtn" type="button" class="secondary-btn" data-loc="client.topup.openWallet">Open wallet</button>
            <button id="openDepositAltBtn" type="button" class="secondary-btn" data-loc="client.topup.openAlternative">Open fallback link</button>
            <button id="copyDepositAddressBtn" type="button" class="secondary-btn" data-loc="client.topup.copyAddress">Copy address</button>
            <button id="copyDepositMemoBtn" type="button" class="secondary-btn" data-loc="client.topup.copyMemo">Copy memo</button>
            <button id="copyDepositTxBtn" type="button" class="secondary-btn" data-loc="client.topup.copyTx">Copy tx id</button>
            <button id="checkDepositStatusBtn" type="button" class="secondary-btn" data-loc="client.topup.checkStatus">Check status</button>
          </div>
        </section>
      </div>

      <div id="profileInviteScreen" class="card stack profile-screen" hidden>
        <button id="backFromInviteBtn" type="button" class="profile-back-btn" data-loc-aria-label="client.button.back">←</button>
        <div class="section-header">
          <div class="section-title" data-loc="client.profile.menuInvite">Invite Friend</div>
        </div>
        <div class="section-subtitle" data-loc="client.profile.promoTitle">Enter promo code</div>
        <input id="promoCodeInput" type="text" maxlength="64" placeholder="Promo code" data-loc-placeholder="client.profile.promoPlaceholder" class="profile-input" />
        <button id="applyPromoBtn" type="button" data-loc="client.button.applyPromo">Apply promo code</button>
        <div id="promoStatus" class="muted"></div>

        <div class="section-subtitle" data-loc="client.referral.title">Invite friends</div>
        <div class="draw-meta-row"><span data-loc="client.referral.codeLabel">Your invite code:</span> <strong id="referralCodeText">-</strong></div>
        <button id="copyReferralLinkBtn" type="button" class="secondary-btn" data-loc="client.referral.copyLink">Copy invite link</button>
        <div id="referralStatus" class="muted"></div>
      </div>

      <div id="profileWithdrawScreen" class="card stack profile-screen" hidden>
        <button id="backFromWithdrawBtn" type="button" class="profile-back-btn" data-loc-aria-label="client.button.back">←</button>
        <div class="section-header">
          <div class="section-title" data-loc="client.profile.menuWithdraw">Withdraw Money</div>
        </div>
        <div class="section-subtitle" data-loc="client.profile.savedWallet">Saved wallet address</div>
        <input id="walletAddressInput" type="text" maxlength="256" placeholder="Bitcoin wallet address" data-loc-placeholder="client.profile.walletPlaceholder" class="profile-input" />
        <button id="saveWalletAddressBtn" type="button" data-loc="client.button.saveWallet">Save wallet address</button>
        <div id="walletAddressStatus" class="muted"></div>

        <div class="section-subtitle" data-loc="client.profile.withdrawTitle">Request withdrawal</div>
        <input id="withdrawAmountInput" type="number" min="0.01" step="0.01" placeholder="Amount" data-loc-placeholder="client.profile.amountPlaceholder" class="profile-input" />
        <input id="withdrawNumberInput" type="text" maxlength="256" placeholder="Wallet address (or leave empty to use saved)" data-loc-placeholder="client.profile.withdrawAddressPlaceholder" class="profile-input" />
        <button id="withdrawBtn" type="button" data-loc="client.button.withdraw">Withdraw</button>
        <div id="withdrawStatus" class="muted"></div>
      </div>

      <div id="profileHistoryScreen" class="card stack profile-screen" hidden>
        <button id="closeHistoryBtn" type="button" class="profile-back-btn" data-loc-aria-label="client.button.back">←</button>
        <div class="section-header">
          <div class="section-title" data-loc="client.history.title">Transaction history</div>
        </div>
        <div id="historyStatus" class="muted"></div>
        <div id="historyEmpty" class="empty-card" data-loc="client.history.empty">No transactions yet.</div>
        <div id="historyList" class="history-list"></div>
      </div>
    </section>
  </main>

  <div id="ticketPurchaseScreen" class="purchase-screen" hidden>
    <div id="ticketPurchasePanel" class="purchase-screen-panel" role="dialog" aria-modal="true" aria-labelledby="ticketPurchaseTitle">
      <div class="purchase-screen-header">
        <div class="purchase-screen-header-copy">
          <div id="ticketPurchaseTitle" class="section-title" data-loc="client.purchaseScreen.title">Pick your tickets</div>
          <div id="ticketPurchaseSubtitle" class="section-subtitle" data-loc="client.purchaseScreen.subtitle">Complete one or more tickets to buy them together.</div>
        </div>
        <button id="closeTicketPurchaseScreenBtn" type="button" class="purchase-screen-close-btn" aria-label="Close purchase screen" data-loc-aria-label="client.purchaseScreen.closeAria">×</button>
      </div>

      <div class="purchase-screen-draw-meta">
        <div class="purchase-screen-draw-meta-line">
          <span data-loc="client.purchaseScreen.drawPrefix">Draw #</span>
          <strong id="ticketPurchaseDrawId">-</strong>
        </div>
        <div class="purchase-screen-draw-meta-line">
          <span data-loc="client.currentDraw.ticketCostPrefix">Ticket cost:</span>
          <strong id="ticketPurchaseDrawCost">$0.00</strong>
        </div>
      </div>

      <div id="ticketPurchaseScreenStatus" class="muted purchase-screen-status"></div>
      <div id="ticketPurchaseTicketsList" class="purchase-ticket-list"></div>

      <div id="ticketPurchaseFooter" class="purchase-screen-footer" hidden>
        <button id="submitTicketPurchaseBtn" type="button" class="purchase-screen-submit-btn">
          <span id="submitTicketPurchaseLabel">Purchase tickets</span>
          <span id="submitTicketPurchaseCost">$0.00</span>
        </button>
      </div>
    </div>
  </div>

  <nav class="tabbar" aria-label="Bottom tabs" data-loc-aria-label="client.tabbar.aria">
    <button id="lotteryTabBtn" type="button" class="tabbar-btn tabbar-btn-active"><span data-loc="client.tab.home">Home</span></button>
    <button id="ticketsTabBtn" type="button" class="tabbar-btn"><span data-loc="client.tab.tickets">My Tickets</span> <span id="ticketsWinningPin" class="tickets-winning-pin" hidden>0</span></button>
    <button id="winnersTabBtn" type="button" class="tabbar-btn"><span data-loc="client.tab.winners">Winners</span></button>
    <button id="profileTabBtn" type="button" class="tabbar-btn"><span data-loc="client.tab.profile">Profile</span></button>
  </nav>

  <div id="centerPopup" class="center-popup" hidden>
    <div id="centerPopupBackdrop" class="center-popup-backdrop"></div>
    <div class="center-popup-card" role="dialog" aria-modal="true" aria-labelledby="centerPopupMessage">
      <div class="center-popup-header" data-loc="client.popup.error">Error</div>
      <div id="centerPopupMessage" class="center-popup-message"></div>
      <button id="centerPopupConfirmBtn" type="button" class="center-popup-confirm" data-loc="client.popup.confirm">Confirm</button>
    </div>
  </div>

  <script src="~/js/miniapp.js" asp-append-version="true"></script>
</body>
</html>
