@page
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lotto</title>

  <meta name="theme-color" content="#0b1019" />
  <meta name="msapplication-navbutton-color" content="#0b1019" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="~/css/miniapp.css" asp-append-version="true" />
</head>
<body class="app-loading">
  <div id="appLoadingShell" class="loading-shell" aria-hidden="true">
    <div class="container loading-shell-inner">
      <div class="loading-shell-topbar">
        <div class="loading-skeleton loading-skeleton-circle"></div>
        <div class="loading-skeleton loading-skeleton-title"></div>
      </div>

      <section class="loading-shell-card loading-shell-hero">
        <div class="loading-shell-row">
          <div class="loading-skeleton loading-skeleton-chip"></div>
          <div class="loading-skeleton loading-skeleton-time"></div>
        </div>
        <div class="loading-skeleton loading-skeleton-amount"></div>
        <div class="loading-skeleton loading-skeleton-copy"></div>
        <div class="loading-shell-pills">
          <div class="loading-skeleton loading-skeleton-pill"></div>
          <div class="loading-skeleton loading-skeleton-pill"></div>
          <div class="loading-skeleton loading-skeleton-pill"></div>
        </div>
      </section>

      <section class="loading-shell-card loading-shell-main">
        <div class="loading-shell-row">
          <div class="loading-skeleton loading-skeleton-title loading-skeleton-title-sm"></div>
          <div class="loading-skeleton loading-skeleton-badge"></div>
        </div>
        <div class="loading-skeleton loading-skeleton-line"></div>
        <div class="loading-skeleton loading-skeleton-button"></div>
        <div class="loading-skeleton loading-skeleton-line loading-skeleton-line-wide"></div>
      </section>

      <section class="loading-shell-card loading-shell-list">
        <div class="loading-shell-row">
          <div class="loading-skeleton loading-skeleton-title loading-skeleton-title-sm"></div>
          <div class="loading-skeleton loading-skeleton-badge"></div>
        </div>
        <div class="loading-skeleton loading-skeleton-ticket"></div>
        <div class="loading-skeleton loading-skeleton-ticket"></div>
      </section>

      <nav class="loading-shell-tabbar" aria-label="Loading tabs">
        <div class="loading-skeleton loading-skeleton-tab"></div>
        <div class="loading-skeleton loading-skeleton-tab"></div>
        <div class="loading-skeleton loading-skeleton-tab"></div>
      </nav>
    </div>
  </div>

  <main id="appShell" class="container app-shell" aria-busy="true">
    <section id="lotteryTabPanel" class="tab-panel stack">
      <header class="topbar">
        <div class="brand">
          <div class="brand-icon">⚡</div>
          <div class="brand-title">LottoVibe</div>
        </div>
        <div class="balance-block">
          <div class="balance-label">Money</div>
          <div id="userBalanceText" class="balance-value">$0.00</div>
        </div>
      </header>

      <div id="debugModeBadge" class="debug-mode-badge" hidden></div>

      <section class="card jackpot-card">
        <div class="jackpot-top">
          <span class="jackpot-chip">Jackpot alert</span>
          <span class="jackpot-time" id="currentDrawCreatedAt">Ends in --:--:--</span>
        </div>
        <div class="jackpot-amount" id="jackpotAmount">$0.00</div>
        <p class="jackpot-copy" id="jackpotSubtitle">The next draw is coming soon. Get your tickets now.</p>
        <div id="currentDrawPrizeTiers" class="prize-tier-row" hidden>
          <div class="prize-tier-pill">
            <span class="prize-tier-label">3/5</span>
            <span class="prize-tier-value" id="currentDrawPrizePool3">$0.00</span>
          </div>
          <div class="prize-tier-pill">
            <span class="prize-tier-label">4/5</span>
            <span class="prize-tier-value" id="currentDrawPrizePool4">$0.00</span>
          </div>
          <div class="prize-tier-pill">
            <span class="prize-tier-label">5/5</span>
            <span class="prize-tier-value" id="currentDrawPrizePool5">$0.00</span>
          </div>
        </div>
      </section>

      <section id="currentDrawCard" class="card stack current-draw-card">
        <div class="draw-accent"></div>
        <div class="section-header">
          <div>
            <div class="section-title" id="currentDrawId">PowerBall Global</div>
            <div class="section-subtitle" id="currentDrawSubtitle">Next draw and ticket purchase</div>
          </div>
          <div id="currentDrawStateBadge" class="state-badge state-badge-muted">waiting</div>
        </div>

        <div id="currentDrawEmpty" class="empty-card">There is no active draw right now.</div>

        <div id="currentDrawContent" class="stack" hidden>
          <div id="currentDrawPurchaseBlock" class="stack">
            <div id="currentDrawTicketPriceRow" class="draw-meta-row">
              <span>Ticket cost: <strong id="currentDrawTicketCost">$2.00</strong> per entry.</span>
            </div>

            <button id="purchaseTicketBtn" type="button">Purchase ticket</button>
            <div id="purchaseStatus" class="muted"></div>
          </div>

          <div id="currentDrawNumbersWrap" class="stack" hidden>
            <div class="section-subtitle">Winning numbers</div>
            <div id="currentDrawNumbers"></div>
          </div>
        </div>
      </section>

    </section>

    <section id="ticketsTabPanel" class="tab-panel stack" hidden>
      <div class="card stack">
        <div class="section-header tickets-header">
          <div class="section-title">My tickets</div>
        </div>
        <div id="timelineStatus" class="section-subtitle"></div>
        <div id="myTicketsEmpty" class="empty-card">You have not bought any tickets yet.</div>
        <div id="myTicketsList" class="history-list"></div>
      </div>
    </section>

    <section id="profileTabPanel" class="tab-panel stack" hidden>
      <div class="card stack">
        <div class="section-title">Profile</div>
        <div class="section-subtitle">Manage your wallet balance.</div>
        <div class="draw-meta-row">Current balance: <strong id="profileBalanceText">$0.00</strong></div>
        <button id="topUpBtn" type="button">Deposit crypto</button>
        <div id="topUpStatus" class="muted"></div>

        <div class="section-subtitle">Saved wallet address</div>
        <input id="walletAddressInput" type="text" maxlength="256" placeholder="Bitcoin wallet address" class="profile-input" />
        <button id="saveWalletAddressBtn" type="button">Save wallet address</button>
        <div id="walletAddressStatus" class="muted"></div>

        <div class="section-subtitle">Request withdrawal</div>
        <input id="withdrawAmountInput" type="number" min="0.01" step="0.01" placeholder="Amount" class="profile-input" />
        <input id="withdrawNumberInput" type="text" maxlength="256" placeholder="Wallet address (or leave empty to use saved)" class="profile-input" />
        <button id="withdrawBtn" type="button">Withdraw</button>
        <div id="withdrawStatus" class="muted"></div>

        <button id="openHistoryBtn" type="button" class="secondary-btn">Transaction history</button>
      </div>

      <div id="historyScreen" class="card stack" hidden>
        <div class="section-header">
          <div class="section-title">Transaction history</div>
          <button id="closeHistoryBtn" type="button" class="secondary-btn">Back</button>
        </div>
        <div id="historyStatus" class="muted"></div>
        <div id="historyEmpty" class="empty-card">No transactions yet.</div>
        <div id="historyList" class="history-list"></div>
      </div>
    </section>
  </main>

  <div id="ticketPickerSheet" class="sheet" hidden>
    <div id="ticketPickerBackdrop" class="sheet-backdrop"></div>
    <div class="sheet-panel ticket-picker-panel">
      <div class="sheet-header">
        <div>
          <div class="section-title">Pick your numbers</div>
          <div class="section-subtitle">Choose 5 unique numbers from 1 to 36.</div>
        </div>
        <button id="closeTicketPickerBtn" type="button" class="sheet-close-btn" aria-label="Close picker">x</button>
      </div>

      <div id="ticketPickerGrid" class="ticket-picker-grid" aria-label="Number picker"></div>

      <div id="ticketPickerStatus" class="muted"></div>
      <button id="confirmTicketNumbersBtn" type="button">Confirm numbers</button>
    </div>
  </div>

  <nav class="tabbar" aria-label="Bottom tabs">
    <button id="lotteryTabBtn" type="button" class="tabbar-btn tabbar-btn-active">Home</button>
    <button id="ticketsTabBtn" type="button" class="tabbar-btn">My Tickets <span id="ticketsWinningPin" class="tickets-winning-pin" hidden>0</span></button>
    <button id="profileTabBtn" type="button" class="tabbar-btn">Profile</button>
  </nav>

  <div id="centerPopup" class="center-popup" hidden>
    <div id="centerPopupBackdrop" class="center-popup-backdrop"></div>
    <div class="center-popup-card" role="dialog" aria-modal="true" aria-labelledby="centerPopupMessage">
      <div class="center-popup-header">Error</div>
      <div id="centerPopupMessage" class="center-popup-message"></div>
      <button id="centerPopupConfirmBtn" type="button" class="center-popup-confirm">Confirm</button>
    </div>
  </div>

  <script src="~/js/miniapp.js" asp-append-version="true"></script>
</body>
</html>
