@page
@{ Layout = null; }
<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Mini App</title>

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="/css/miniapp.css" />
</head>
<body>
  <main class="container">
    <h1>Lotto Mini App</h1>
    <p id="info" class="muted"></p>

    <section class="mt-3">
      <button id="purchaseTicketBtn" type="button">Purchase Ticket</button>
      <p id="purchaseStatus" class="muted" style="margin-top: 0.75rem;"></p>
    </section>

    <section class="mt-3">
      <h2 style="margin-top: 1.5rem;">Your tickets</h2>
      <div id="ticketsEmpty" class="muted">No tickets yet.</div>
      <ul id="ticketsList"></ul>
    </section>

    <button id="closeBtn" type="button" style="margin-top: 1.5rem;">Close</button>
  </main>

  <script src="/js/miniapp.js"></script>
</body>
</html>
