@page
@using MiniApp.Features.Auth
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lotto</title>
  <meta name="theme-color" content="#ffffff" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <script>
    try {
      window.__serverLocalDebug = @(LocalDebugMode.IsEnabled(Configuration, Environment) ? "true" : "false");
    } catch (e) { window.__serverLocalDebug = false; }
  </script>
  @if (LocalDebugMode.IsEnabled(Configuration, Environment))
  {
    <link rel="stylesheet" href="~/css/miniapp-home-fallback.css" asp-append-version="true" />
  }
  else
  {
    <link rel="stylesheet" href="~/dist/assets/index.css" asp-append-version="true" />
  }
</head>
<body>
  <div id="app"></div>
  @if (LocalDebugMode.IsEnabled(Configuration, Environment))
  {
    <script src="~/js/miniapp-home-fallback.js" asp-append-version="true"></script>
  }
  else
  {
    <script type="module" src="~/dist/assets/index.js" asp-append-version="true"></script>
  }
  <noscript>This app requires JavaScript.</noscript>
  <script>
    window.addEventListener('error', function (event) {
      try {
        console.error('MiniApp host error', event && event.message ? event.message : event);
      } catch {}
    });

    window.addEventListener('DOMContentLoaded', function () {
      var appRoot = document.getElementById('app');
      if (!appRoot) return;

      window.setTimeout(function () {
        if (appRoot.children.length === 0 && !appRoot.innerHTML.trim()) {
          appRoot.innerHTML = '<div style="padding:16px;font-family:Arial,sans-serif;color:#111">Frontend did not mount. Open <code>/debug/frontend-status</code> and browser console.</div>';
        }
      }, 2500);
    });
  </script>
</body>
</html>