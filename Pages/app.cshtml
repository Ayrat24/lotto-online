@page
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lotto</title>

  <meta name="theme-color" content="#0b1019" />
  <meta name="msapplication-navbutton-color" content="#0b1019" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="~/css/miniapp.css" asp-append-version="true" />
</head>
<body>
  <main class="container app-shell">
    <section id="lotteryTabPanel" class="tab-panel stack">
      <header class="topbar">
        <div class="brand">
          <div class="brand-icon">⚡</div>
          <div class="brand-title">LottoVibe</div>
        </div>
        <div class="balance-block">
          <div class="balance-label">Balance</div>
          <div class="balance-value" id="currentDrawPrizePool">$0.00</div>
        </div>
      </header>

      <div id="debugModeBadge" class="debug-mode-badge" hidden></div>

      <section class="card jackpot-card">
        <div class="jackpot-top">
          <span class="jackpot-chip">Jackpot alert</span>
          <span class="jackpot-time" id="currentDrawCreatedAt">Ends in --:--:--</span>
        </div>
        <div class="jackpot-amount" id="jackpotAmount">$0.00</div>
        <p class="jackpot-copy" id="jackpotSubtitle">The next draw is coming soon. Get your tickets now.</p>
      </section>

      <section id="currentDrawCard" class="card stack current-draw-card">
        <div class="draw-accent"></div>
        <div class="section-header">
          <div>
            <div class="section-title" id="currentDrawId">PowerBall Global</div>
            <div class="section-subtitle">Next draw and ticket purchase</div>
          </div>
          <div id="currentDrawStateBadge" class="state-badge state-badge-muted">waiting</div>
        </div>

        <div id="currentDrawEmpty" class="empty-card">There is no active draw right now.</div>

        <div id="currentDrawContent" class="stack" hidden>
          <div class="draw-meta-row">
            <span>Tickets start at <strong>$2.00</strong> per entry.</span>
          </div>

          <div id="currentDrawNumbersWrap" class="stack" hidden>
            <div class="section-subtitle">Winning numbers</div>
            <div id="currentDrawNumbers"></div>
          </div>
        </div>

        <button id="purchaseTicketBtn" type="button">Purchase ticket</button>
        <div id="purchaseStatus" class="muted"></div>
      </section>

      <section class="stack">
        <div class="section-header tickets-header">
          <div class="section-title">Active tickets</div>
          <button id="openHistoryBtn" type="button" class="link-btn">View all</button>
        </div>
        <div id="timelineStatus" class="section-subtitle"></div>
        <div id="currentTicketsEmpty" class="empty-card">You have not bought any tickets for the current draw yet.</div>
        <div id="currentTicketsList" class="ticket-list"></div>
      </section>
    </section>

    <section id="accountTabPanel" class="tab-panel stack" hidden>
      <div class="card stack">
        <div class="section-title">My tickets</div>
        <div class="section-subtitle">Tap View all in Active tickets for the complete history.</div>
      </div>
    </section>
  </main>

  <div id="historySheet" class="sheet" hidden>
    <div id="historyBackdrop" class="sheet-backdrop"></div>
    <div class="sheet-panel">
      <div class="sheet-header">
        <div>
          <div class="section-title">History</div>
          <div class="section-subtitle">Your past draws and purchased tickets.</div>
        </div>
        <button id="closeHistoryBtn" type="button" class="sheet-close-btn" aria-label="Close history">×</button>
      </div>

      <div id="historyEmpty" class="empty-card">No ticket history yet.</div>
      <div id="historyList" class="history-list"></div>
    </div>
  </div>

  <div id="ticketPickerSheet" class="sheet" hidden>
    <div id="ticketPickerBackdrop" class="sheet-backdrop"></div>
    <div class="sheet-panel ticket-picker-panel">
      <div class="sheet-header">
        <div>
          <div class="section-title">Pick your numbers</div>
          <div class="section-subtitle">Choose 5 unique numbers from 1 to 36.</div>
        </div>
        <button id="closeTicketPickerBtn" type="button" class="sheet-close-btn" aria-label="Close picker">x</button>
      </div>

      <div id="ticketPickerGrid" class="ticket-picker-grid" aria-label="Number picker"></div>

      <div id="ticketPickerStatus" class="muted"></div>
      <button id="confirmTicketNumbersBtn" type="button">Confirm numbers</button>
    </div>
  </div>

  <nav class="tabbar" aria-label="Bottom tabs">
    <button id="lotteryTabBtn" type="button" class="tabbar-btn tabbar-btn-active">Home</button>
    <button id="accountTabBtn" type="button" class="tabbar-btn">My Tickets</button>
    <button type="button" class="tabbar-btn" disabled>Results</button>
    <button type="button" class="tabbar-btn" disabled>History</button>
    <button type="button" class="tabbar-btn" disabled>Profile</button>
  </nav>

  <script src="~/js/miniapp.js" asp-append-version="true"></script>
</body>
</html>
