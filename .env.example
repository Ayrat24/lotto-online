# Copy to .env and set real values before running docker-compose.app.yml
# Use strong random secrets in production.

BOT_TOKEN=
BOT_WEBAPP_URL=
# Required when BotMode=Webhook (the default in docker-compose.app.yml).
# 1-256 chars, A-Z a-z 0-9 _ - . Generate e.g. with: openssl rand -hex 32
BOT_WEBHOOK_SECRET_TOKEN=replace-with-a-long-random-webhook-secret
ADMIN_USERNAME=admin-panel
ADMIN_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=miniapp
POSTGRES_USER=miniapp
POSTGRES_PASSWORD=replace-with-a-long-random-db-password

